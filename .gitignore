# Sentry — never commit auth tokens or wizard-generated rc files.
# `.sentryclirc` is generated by `npx @sentry/wizard` and contains an
# auth token; `.env.sentry-build-plugin` is the alternate plugin-format.
# See docs/runtime-alerting-2026-05-18.md.
.sentryclirc
.env.sentry-build-plugin
