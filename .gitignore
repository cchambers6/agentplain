.claude/worktrees/

# prisma generated
/prisma/generated/

# Sentry — never commit auth tokens or wizard-generated rc files.
# `.sentryclirc` is generated by `npx @sentry/wizard` and contains an
# auth token; `.env.sentry-build-plugin` is the alternate plugin-format.
# See docs/runtime-alerting-2026-05-18.md.
.sentryclirc
.env.sentry-build-plugin

# Fleet automation tokens — short-lived GitHub tokens minted by the fleet
# push/PR mechanism. NEVER commit. Live only on local disk; in-memory preferred.
.fleet-token*.txt
.fleet-token*.err
*.fleet-token.txt
*.fleet-token.err
.night-*.mjs
.night-*.md
.mk-junction*.mjs
.pr-body*.md
pr-sweep.mjs
*.private-key*
.playwright-mcp/

# Playwright E2E artifacts
playwright-report/
test-results/
blob-report/
