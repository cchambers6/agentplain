#!/usr/bin/env sh
# Pre-push hook — staleness gate + full-repo lint + build gate.
#
# Layer 0 (staleness gate): refuse pushes when the branch is too far behind origin/main.
# Stale-base branches keep tripping Vercel preview lint with errors that are already fixed
# on main (see ~/.claude/projects/C--agentplain/memory/feedback_code_tasks_rebase_first.md).
# Threshold is 5 commits — small enough to catch genuinely stale branches (the cases that
# triggered this rule were 10+ behind), large enough to not nag on every-day work.
# Emergency escape hatch: SKIP_PREPUSH_REBASE_GATE=1 git push ...
#
# Layer 1 (full-repo lint): belt-and-suspenders against the per-file pre-commit pass.
# Catches cross-file rule violations and bypassed pre-commits.
# Bypass with `git push --no-verify` only in genuine emergencies; document why in the commit.
# See outputs/systematic_main_protection/design.md §Layer 1.
#
# Layer 2 (build gate): refuse pushes that don't compile. Added 2026-05-18 after
# shipping broken main twice in one week — a TS error in `scripts/verify-knowledge-seed.ts`
# and the verify-page cookie crash both landed because the pre-push pipeline only ran
# lint, not the full Next.js build. `build:no-migrate` is the build command without the
# Prisma `migrate deploy` step, so it's safe to run from any developer machine and
# doesn't require a live DATABASE_URL. Emergency escape hatch: HUSKY=0 git push ...
# (documented in docs/incident-log.md alongside the broken-main entries).

# --- Layer 0: staleness gate ---
if [ "${SKIP_PREPUSH_REBASE_GATE:-0}" != "1" ]; then
  git fetch origin --quiet
  THRESHOLD=5
  BEHIND=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo 0)
  if [ "$BEHIND" -gt "$THRESHOLD" ]; then
    echo ""
    echo "❌ Push blocked: branch is $BEHIND commits behind origin/main."
    echo "   Rebase before pushing to avoid stale-base CI failures (per feedback_code_tasks_rebase_first.md)."
    echo "   Run:  git fetch origin && git rebase origin/main"
    echo "   Or to skip this gate (escape hatch): SKIP_PREPUSH_REBASE_GATE=1 git push ..."
    echo ""
    exit 1
  fi
fi

# --- Layer 1: lint ---
npm run lint || exit 1

# --- Layer 1.5: brand gate (fast, dependency-free) ---
# Vendor names / placeholder assets / token drift / banned words on customer
# surfaces. Baseline ratchet — only NEW violations fail. Wired 2026-06-11 once
# the design-remediation waves drove the baseline to zero (PRs #227-#234).
npm run brand-gate || {
  echo "❌ Push blocked: brand-gate found new brand-standard violations (see docs/brand/brand-gate.md)."
  exit 1
}

# --- Layer 1.6: connector dispatch-coverage gate (fast, dependency-free) ---
# Every marketplace connector marked status:"available" must have a live MCP
# dispatch route at app/api/integrations/<slug>/[workspaceId]/route.ts. Wired
# 2026-06-15 after the click-path triage found HubSpot/Salesforce/Notion/FUB/
# Sierra/Buildium connected + synced but had no dispatch route — so every agent
# action through them silently 404'd ("every button feels broken").
npm run check:connector-dispatch || {
  echo "❌ Push blocked: a connectable connector is missing its MCP dispatch route."
  echo "   Add the route, or mark the connector status:\"coming-soon\" in lib/integrations/marketplace.ts."
  exit 1
}

# --- Layer 2: build gate ---
echo ""
echo "▶ Running build gate (npm run build:no-migrate) — catches TS errors + broken pages before push."
echo "  Emergency bypass: HUSKY=0 git push ...  (document the bypass in docs/incident-log.md)"
echo ""
npm run build:no-migrate || {
  echo ""
  echo "❌ Push blocked: build:no-migrate failed."
  echo "   Fix the build before pushing, or bypass with HUSKY=0 git push ... (document in docs/incident-log.md)."
  echo ""
  exit 1
}

# --- Layer 3: schema-drift gate with raw-index auto-heal (Wave-7, theme #19) ---
# When a SHADOW_DATABASE_URL is available, run the drift check in auto-heal
# mode. If the only drift is a new raw-SQL index migration (GIN/trgm/pgvector),
# the check appends the DROP INDEX line to prisma/schema-drift-baseline.sql
# automatically — the documented fix — instead of leaving HUSKY=0 as the only
# way forward. ANY other drift still fails loud (the gate is NOT weakened).
# Skipped entirely when no shadow DB is configured (the common local case),
# so this never blocks a push on a machine without Postgres and never
# interferes with a parallel wave's push.
if [ -n "${SHADOW_DATABASE_URL:-}" ]; then
  echo ""
  echo "▶ Running schema-drift gate (auto-heals raw-index drift; other drift fails loud)."
  npm run check:schema-drift -- --auto-heal-raw-indexes || {
    echo ""
    echo "❌ Push blocked: schema drift beyond the known raw-index pattern."
    echo "   Resolve with 'npx prisma migrate dev' or '--update-baseline' + a README note."
    echo "   (Do NOT use HUSKY=0 — that is the jailbreak this gate exists to remove.)"
    echo ""
    exit 1
  }
  # If the auto-heal modified the baseline, the push would otherwise ship a
  # dirty working tree. Surface it so the developer commits the healed file.
  if ! git diff --quiet -- prisma/schema-drift-baseline.sql; then
    echo ""
    echo "❌ Push blocked: schema-drift auto-heal updated prisma/schema-drift-baseline.sql."
    echo "   Review + commit the healed baseline, then push again:"
    echo "     git add prisma/schema-drift-baseline.sql && git commit --amend --no-edit"
    echo ""
    exit 1
  fi
fi
