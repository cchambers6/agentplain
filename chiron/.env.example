# --- Database ---
# Postgres connection string (Neon free tier covers the POC).
DATABASE_URL="postgresql://user:password@localhost:5432/chiron"

# --- Auth (single family per install; no auth provider in POC) ---
# The one parent account allowed to sign in.
FAMILY_ADMIN_EMAIL="parent@example.com"
# Random 32+ char string used to sign the session cookie.
SESSION_SECRET="replace-with-a-long-random-string"

# --- AI provider keys, by tier (never commit real keys) ---
# Tier names are capability labels, not vendor names. Point each at the
# provider/model tier configured in lib/ai/route.ts. Internal-only surface:
# no tier or vendor name ever renders on a parent-facing page.
AI_HEAVY_API_KEY=""           # heavy-reasoning tier (weekly planning, integration runs)
AI_CONVERSATIONAL_API_KEY=""  # mid tier (daily debrief conversation)
AI_LIGHTWEIGHT_API_KEY=""     # triage/cheap tier (morning brief, extraction triage)

# --- AI mode ---
# "mock" serves the canned Hartfield IntegrationMap + WeeklyPlan instead of
# calling any provider — lets the preview deploy render /plan with no keys.
# Unset (or anything else) = live calls via the tier keys above.
CHIRON_AI_MODE=""

# --- Jobs ---
# Shared secret guarding the Vercel Cron endpoints.
CRON_SECRET="replace-with-a-long-random-string"
