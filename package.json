{
  "name": "agentplain",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "build:no-migrate": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/*.test.ts\" \"lib/**/*.test.ts\"",
    "test:ui": "tsx --tsconfig ./tests/tsconfig.test.json --test \"tests/customer-workspace-home.test.tsx\" \"tests/customer-approvals.test.tsx\" \"tests/customer-talk.test.tsx\" \"tests/customer-settings-states.test.tsx\" \"tests/customer-visibility-states.test.tsx\" \"tests/operator-workspace-detail.test.tsx\" \"tests/plaino-widget-lead-capture.test.tsx\" \"tests/plaino-avatar.test.tsx\" \"tests/plaino-scene-wiring.test.tsx\"",
    "check:schema-drift": "tsx scripts/check-schema-drift.ts",
    "encrypt:payloads-at-rest": "tsx scripts/encrypt-payloads-at-rest.ts",
    "prisma:generate": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@notionhq/client": "^5.20.0",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.53.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "google-auth-library": "^9.15.1",
    "googleapis": "^144.0.0",
    "inngest": "^4.2.6",
    "iron-session": "^8.0.4",
    "next": "14.2.18",
    "prisma": "^6.19.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.12.3",
    "stripe": "^22.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.40",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.18",
    "husky": "^9.1.7",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3"
  }
}
