// agentplain Phase 1 — broker-owner-only customer surface.
// Schema is deliberately small. Phase 2 adds operator overlay + multi-workspace.
// Phase 3 native adds AGENT role, AgentSeat, DraftReply, Thread.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

// Role taxonomy. The original two values (BROKER_OWNER, AGENT) shipped in
// Phase 1 when every workspace was a single owner. Wave 6 adds the
// generalized tier set (OWNER, ADMIN, MEMBER, VIEWER) so multi-seat
// workspaces can model real team structure. BROKER_OWNER and OWNER are
// equivalent at the policy layer (`lib/auth/roles.ts#asRoleTier`); AGENT
// and MEMBER are equivalent. New code SHOULD write OWNER / MEMBER; legacy
// rows continue to read as the same tier so no backfill migration is
// needed.
enum Role {
  BROKER_OWNER
  AGENT
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MembershipStatus {
  INVITED
  ACTIVE
  DEACTIVATED
}

// Legacy Phase 1 tier — pre-§13 audience-tier framing (Spec lines 117–149).
// Kept on Workspace for backward-compat with shipped Phase 1 invoices / billing
// modes. New product surfaces read Workspace.verticalTier instead. Slated for
// drop in Phase 2 alongside the migration plan in §13.7 of product_spec.md.
enum WorkspaceTier {
  HIGH_TOUCH
  SCALED
}

// agentplain — nine launch verticals. Mirrors project_vertical_tier_mapping
// and product_spec.md §13.2. Medical practices intentionally excluded per
// feedback_no_new_verticals_finish_locked (reactivate when a HIPAA customer
// asks). Adding a vertical requires a memory-tracked decision.
enum Vertical {
  REAL_ESTATE
  MORTGAGE
  INSURANCE
  PROPERTY_MANAGEMENT
  TITLE_ESCROW
  RECRUITING
  HOME_SERVICES
  CPA
  LAW
  RIA
}

// Per-seat tier ladder ratified 2026-05-09. Supersedes WorkspaceTier above.
// Pricing in lib/pricing/tiers.ts; mapping verticals→tiers in lib/verticals.
// product_spec.md §13.1 lines 420–441.
enum WorkspaceVerticalTier {
  REGULAR
  PLUS
  MAX
}

enum WorkspaceBillingMode {
  MANUAL_INVOICE
  STRIPE_SUBSCRIPTION
}

// Customer-initiated workspace closure state machine. ACTIVE is the default;
// CLOSING is the cancellable soft-delete window; CLOSED is the post-purge
// resting state (Workspace + Membership rows survive for audit/billing
// history; every tenant-data child table is empty per
// `lib/customer-files/deletion.ts#tearDownWorkspaceData`). See
// `prisma/migrations/20260527000000_add_workspace_closure/migration.sql`.
enum WorkspaceClosureStatus {
  ACTIVE
  CLOSING
  CLOSED
}

// Per-seat subscription lifecycle. Mirrors Stripe's subscription.status
// taxonomy 1:1 so webhook payloads upsert without translation. PAUSED
// accepts the value Stripe emits when a trial ends without a payment
// method on a subscription created with
// trial_settings.end_behavior.missing_payment_method="pause" — before
// the wave-2 CC-at-trial pivot every signup hit this path, the webhook
// upsert threw on the unknown enum, and the route returned 500 (audit
// §6, 2026-05-28). CC-at-trial avoids the path going forward; the
// enum value stays for Phase-1 high-touch rows that may still pause and
// for future Stripe pause-collection workflows.
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  INCOMPLETE
  INCOMPLETE_EXPIRED
  CANCELED
  UNPAID
  PAUSED
}

// Seat-band axis for the per-seat ladder. Five self-serve bands; the 100+
// "enterprise" row in the canonical table is handled out-of-band via a
// custom build engagement (project_stripe_both_surfaces lines 17–26 + 57–59).
// The enum value is also the Stripe lookup_key suffix so the pricing table,
// the Stripe Prices, and the Subscription row share one stable identifier.
enum SeatBand {
  SEATS_1
  SEATS_2_9
  SEATS_10_24
  SEATS_25_49
  SEATS_50_99
}

// Source surface that produced an LLM call. Tagged onto every
// `LlmUsageRecord` row so the usage pane can break down spend by agent.
// Adding a new surface widens the enum; OTHER is the safety net for any
// LLM call that doesn't yet carry a `sourceSurface` in its meta.
// Mirrors the call-site names already used by `LlmRequestMeta.skill`.
enum LlmSourceSurface {
  PLAINO_CHAT
  OFFICE_ADMIN
  CATEGORIZE
  COORDINATE
  SCHEDULE
  DRAFT
  SUPPORT_HANDLER
  INBOX_TRIAGE
  FOLLOW_UP_CHASER
  PROCESS_DOC_DRAFTER
  SCHEDULER_SWEEP
  MEMORY_EXTRACT
  OTHER
}

enum WorkApprovalKind {
  COMPLIANCE_FLAG
  LISTING_RECOMMENDATION
  BUYER_INQUIRY_REPLY_DRAFT
  PRICING_RECOMMENDATION
  // Office-admin kinds — surfaced by lib/skills/office-admin. Each kind
  // maps to a distinct render in app/(product)/app/workspace/[id]/approvals.
  ADMIN_VERIFICATION_CODE
  ADMIN_PASSWORD_RESET
  ADMIN_TRIAL_ENDING
  ADMIN_BILLING_NOTICE
  ADMIN_SECURITY_ALERT
  // Chief-of-staff scheduler proposal kinds. One enum value per
  // ChiefOfStaffProposal.kind so the approvals UI renders the right
  // affordance (slot picker vs reply draft vs to-do row). Each is
  // ALWAYS draft-only — the customer's own system books/sends/writes;
  // the skill itself never executes. See lib/skills/chief-of-staff-
  // scheduler and project_no_outbound_architecture.md.
  CHIEF_OF_STAFF_MEETING
  CHIEF_OF_STAFF_REPLY_DRAFT
  CHIEF_OF_STAFF_TODO
  // /general runtime catalog kinds. Each maps one production caller
  // (process-webhook-event for INBOX_TRIAGE; follow-up-chaser-sweep
  // for FOLLOW_UP_NUDGE; process-doc-drafter-sweep for PROCESS_DOC_DRAFT)
  // to the approvals UI affordance the operator reviews. Like the
  // chief-of-staff kinds, all three are DRAFT-only — no send, no book,
  // no publish. See lib/skills/{inbox-triage-general,follow-up-chaser-
  // general,process-doc-drafter-general} and project_no_outbound_architecture.md.
  INBOX_TRIAGE
  FOLLOW_UP_NUDGE
  PROCESS_DOC_DRAFT
  // Support-handler draft. Produced by lib/skills/support-handler in
  // response to a customer-submitted SupportRequest (the in-app /help
  // form). Drafts a first-touch reply from the knowledge substrate and
  // queues it for operator review — never sent by agentplain. Operator
  // approves / edits / escalates; the customer's existing email path
  // performs the send.
  SUPPORT_HANDLER_REPLY_DRAFT
  // Plaino INSTRUCT path — fired when /talk classifies a customer
  // message as a request to DO WORK (not a question, not a feedback
  // statement). The Inngest instruction-handler reads this queue item,
  // drafts the work via discipline-tagged LLM call, persists the draft
  // back into the same row's payload, and re-surfaces for operator
  // approval. Draft-only by contract — see lib/plaino/dispatcher.ts.
  PLAINO_INSTRUCTION
  // Vertical webhook router output. The real-estate lead-triage skill
  // categorizes inbound leads (hot/warm/cold/nurture), proposes routing
  // (specific agent / drip campaign / manual), and drafts a first-touch
  // reply — all surfaced in one card under this kind. Draft-only by
  // contract — the broker's CRM picks up routing; their email sends.
  // See lib/skills/lead-triage-realestate + lib/skills/vertical-router.ts.
  LEAD_TRIAGE
  // Wave-3 discipline-wrap kinds. Each maps one cron / event handler
  // to a draft an operator reviews on /approvals. Closes the four
  // NOT-DELIVERING disciplines from the 2026-05-28 fleet-autonomy
  // audit (§10).
  //   ANALYTICS_PULSE  — weekly Monday read of workspace activity,
  //                      composed by lib/skills/analytics-weekly-pulse-
  //                      general into a "Plaino's week in your workspace"
  //                      brief surfaced under the analytics discipline.
  //   RESEARCH_BRIEF   — drafted by lib/skills/research-on-demand-general
  //                      when /talk classifies an instruction as research
  //                      discipline. Substrate-grounded with explicit
  //                      gaps when nothing matched.
  //   CONTENT_CALENDAR — weekly Monday content suggestions composed by
  //                      lib/skills/content-calendar-drafter-general
  //                      under the marketing discipline.
  //   COMPLIANCE_DIGEST — daily 8am sweep by lib/skills/compliance-
  //                       watch-general flagging high-risk patterns
  //                       (PII, regulatory keywords for the vertical,
  //                       missing disclaimers) in last 24h of approval
  //                       drafts. Legal discipline.
  ANALYTICS_PULSE
  RESEARCH_BRIEF
  CONTENT_CALENDAR
  COMPLIANCE_DIGEST
  // Wave-4 — closes the 8th discipline (finance) end-to-end.
  //   FINANCE_PULSE — weekly Monday read of the workspace's finance posture:
  //                   how many invoice-chase / month-end-close drafts the
  //                   fleet produced + decided, and (when QuickBooks is
  //                   connected) AR aging + open-invoice + expense counts
  //                   pulled through the QuickBooks MCP. Composed by
  //                   `lib/skills/finance-pulse-general`. Honest degraded
  //                   mode when QB is not connected — the pulse still fires
  //                   but the body names the "connect QuickBooks for richer
  //                   pulse" gap instead of fabricating numbers.
  FINANCE_PULSE
}

enum WorkApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
  EXPIRED
}

enum ComplianceSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  BLOCKER
}

enum ComplianceFlagState {
  OPEN
  TRIAGED_KEEP
  TRIAGED_REWRITE
  TRIAGED_BLOCK
  RESOLVED
}

enum CapabilityProposalState {
  DRAFT
  AWAITING_VOICE_BLOCK
  AWAITING_REVIEW
  RATIFIED
  REJECTED
  SUPERSEDED
}

// Customer-facing draft-feedback category. The /approvals capture modal
// offers these five; the weekly drift sweep aggregates corrections by
// (targetSkillSlug, category) and proposes a skill tune-up when one
// category accumulates enough corrections. UPPER_SNAKE on the wire; the
// lib/feedback boundary maps to the lowercase labels the UI shows.
enum PreferenceFeedbackCategory {
  TONE
  STRUCTURE
  FACTUAL
  LENGTH
  OTHER
}

// Integration provider taxonomy. GOOGLE = Gmail + Calendar (Phase 1 ships
// Gmail only). M365 (Outlook + Graph) follows in a separate PR once the
// Google path is validated on Conner's dogfood inbox. New providers added
// only after the existing one passes the functional acceptance bar per
// feedback_integration_acceptance_is_functional.
enum IntegrationProvider {
  GOOGLE
  M365
  // Google Drive reuses the GOOGLE credential (same OAuth app, scopes
  // merged via include_granted_scopes) — no enum value of its own.
  DOCUSIGN
  QUICKBOOKS
  SLACK
  // Wave-3 realty CRM. Follow Up Boss is the most-shared realty CRM
  // among small independent brokerages and exposes a self-serve API key
  // (HTTP Basic auth — `accessTokenEncrypted` holds the key; refresh
  // token + expiresAt are unused; `expiresAt` is set to a sentinel
  // far-future date to satisfy the schema's non-null constraint).
  // The MCP server lives at `lib/integrations/follow-up-boss-mcp/`.
  FOLLOW_UP_BOSS
  // Wave-4 realty CRMs. Both Sierra Interactive and BoldTrail expose a
  // per-account API key the brokerage owner pastes in once — no OAuth
  // partner enrollment required. Same accessTokenEncrypted-as-API-key
  // pattern as FOLLOW_UP_BOSS; refresh token + expiresAt unused.
  // Sierra MCP at `lib/integrations/sierra-mcp/`; BoldTrail at
  // `lib/integrations/boldtrail-mcp/`. Each exposes the same 6-tool
  // surface (list_leads, get_lead, create_note, add_tag, list_pipelines,
  // get_pipeline_stage) so the lead-triage skill consumes them through
  // one provider-neutral port.
  SIERRA_INTERACTIVE
  BOLDTRAIL
  // CPA-vertical API-key integrations (wave 5). Both store the key in
  // `accessTokenEncrypted`, leave `refreshTokenEncrypted` NULL, and pin
  // `expiresAt` far in the future — they never refresh. Non-secret
  // routing (TaxDome portal subdomain, Karbon AccessKey) lives in
  // `providerMetadata`.
  TAXDOME
  KARBON
  // Wave-7 universal MCPs. Customer-installable, available across every
  // vertical (the wave-1 to wave-6 integrations were vertical-locked).
  // HubSpot: OAuth2 + long-lived refresh tokens; hub id on
  //   providerMetadata.hubId; MCP at `lib/integrations/hubspot-mcp/`.
  // Salesforce: OAuth2 + instance URL discovery; instance host on
  //   providerMetadata.instanceUrl; MCP at `lib/integrations/salesforce-mcp/`.
  //   Customer-installed dev apps work without partner enrollment; production
  //   sharing requires Connected App enrollment.
  // Notion: workspace-scoped OAuth; access token never expires (no refresh);
  //   bot id + workspace name on providerMetadata; MCP at
  //   `lib/integrations/notion-mcp/`. Connect fires a background substrate-
  //   ingest job that populates pgvector for research-on-demand.
  HUBSPOT
  SALESFORCE
  NOTION
  // Property-management vertical (keystone "port exists, adapter does not"
  // wave). Buildium authenticates with a client-id + client-secret pair the
  // customer creates under Settings → API Settings — neither rotates, so no
  // refresh path (same API-key pattern as TAXDOME / KARBON / FOLLOW_UP_BOSS).
  // Storage: the SECRET in `accessTokenEncrypted`; the non-secret client id
  // in `providerMetadata.clientId`. MCP at `lib/integrations/buildium-mcp/`;
  // it backs the `RentRollLookup` port consumed by the
  // property-management-rent-collection-chase skill. Live calls are gated by
  // BUILDIUM_ADAPTER_LIVE=on (fixtures by default).
  BUILDIUM
  // Wave-1b vertical adapter family — completes the keystone "port exists,
  // adapter does not" finding for insurance / mortgage / title. Each backs a
  // skill port that previously shipped only its JSON fixture impl, and each
  // is gated behind a per-vendor `<VENDOR>_ADAPTER_LIVE=on` flag (fixtures by
  // default). Read-only (`project_no_outbound_architecture.md`).
  //
  // EZLynx (insurance AMS): OAuth2 client-credentials/refresh — the agency
  //   enrolls via EZLynx's partner program. Refresh token in
  //   `refreshTokenEncrypted`; access token in `accessTokenEncrypted`.
  //   MCP at `lib/integrations/ezlynx-mcp/`; backs the `PolicyLookup` port in
  //   the insurance-coi-request skill. Gated by EZLYNX_ADAPTER_LIVE=on.
  // Encompass (ICE Mortgage LOS): OAuth2 + Encompass instance id on
  //   `providerMetadata.instanceId`. Refresh tokens rotate. MCP at
  //   `lib/integrations/encompass-mcp/`; backs the `LoanFileLookup` port in
  //   the mortgage-document-chase skill. Gated by ENCOMPASS_ADAPTER_LIVE=on.
  // Qualia (title/escrow production): HTTP Basic auth (no OAuth, no refresh) —
  //   the org id + API key the customer creates under their Qualia account.
  //   Same API-key credential pattern as BUILDIUM: secret in
  //   `accessTokenEncrypted`, non-secret org id in `providerMetadata.orgId`.
  //   MCP at `lib/integrations/qualia-mcp/`; backs the `ClosingFileFetcher`
  //   port in the title-escrow-closing-doc-chase skill. Gated by
  //   QUALIA_ADAPTER_LIVE=on.
  EZLYNX
  ENCOMPASS
  QUALIA
}

// Credential lifecycle states. ACTIVE = tokens valid and refresh-eligible.
// EXPIRED = access token past expiry AND refresh attempt has not yet
// succeeded; refresh cron tries each fire. REVOKED = customer revoked the
// grant on the provider side (detected when refresh returns invalid_grant).
// ERROR = a non-recoverable provider response (e.g. provider returned 4xx
// other than 401, or a malformed token payload).
enum IntegrationCredentialStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
}

// Webhook subscription lifecycle. ACTIVE = subscription created and not
// near expiry. EXPIRING = within 24h of expires_at; renewal cron picks it
// up. EXPIRED = past expires_at, renewal failed. RENEWAL_FAILED = last
// renewal attempt returned a provider error; cron will retry. UNSUBSCRIBED
// = explicit unsubscribe by operator action.
enum WebhookSubscriptionStatus {
  ACTIVE
  EXPIRING
  EXPIRED
  RENEWAL_FAILED
  UNSUBSCRIBED
}

// Inquiry intake type. Drives operator triage on /operator/inquiries and
// the SLA framing in the customer-facing confirmation. CUSTOM_SKILL_BUILD
// is the existing /custom path (custom skill, integration, white-label,
// bespoke compliance, dedicated success). MAX_SERVICE_ENGAGEMENT is the
// quote-based Max-tier path per `project_stripe_both_surfaces.md` (Max is
// ad-hoc, not productized in Stripe). NOT_SURE keeps visitors who can't
// self-classify out of the failure mode of picking wrong.
enum InquiryType {
  CUSTOM_SKILL_BUILD
  MAX_SERVICE_ENGAGEMENT
  NOT_SURE
}

// Operator triage state for an Inquiry. NEW is the post-submit default;
// TRIAGED_* records Conner's routing decision; DECLINED removes the row
// from the active queue; CONVERTED is the terminal happy-path (workspace
// created, Max engagement signed, or Custom SOW signed — the audit trail
// is in AuditLog, not in this enum).
enum InquiryStatus {
  NEW
  TRIAGED_CUSTOM
  TRIAGED_MAX
  TRIAGED_BOTH
  DECLINED
  CONVERTED
}

// Knowledge substrate context kinds (per project_knowledge_substrate.md).
// Five scopes the fleet's customer-facing answers draw from:
//   SKILL          — capability documentation (read/categorize/coordinate/schedule/draft)
//   CUSTOMER       — workspace-scoped knowledge (CRM facts, prefs, history)
//   VERTICAL       — pattern-level vertical knowledge (real estate vs CPA vs law)
//   CROSS_CUSTOMER — anonymized fleet learnings derived offline
//   COMPLIANCE     — state-by-state + per-vertical rule corpus (fair housing, RESPA, etc.)
//
// workspaceId is NULL for every kind EXCEPT CUSTOMER. The RLS policy on
// Embedding + KnowledgeDocument enforces that customer queries see their
// own rows + every non-customer-scoped row.
enum ContextKind {
  SKILL
  CUSTOMER
  VERTICAL
  CROSS_CUSTOMER
  COMPLIANCE
}

// Customer support routing lifecycle (scaffold — feat/support-routing,
// 2026-05-20; draft-into-review extension — feat/support-draft-into-review-
// handler, 2026-06-03). Lifecycle:
//   NEW       — freshly submitted, untouched.
//   IN_REVIEW — the support-handler fleet drafted a first-touch reply and
//               it is PENDING in the operator approval queue (set by
//               lib/inngest/functions/support-handler-on-create once the
//               draft is sunk). Tells the operator "a draft is waiting".
//   OPEN      — operator is working it by hand (no fleet draft, or the
//               draft was rejected and needs manual handling).
//   RESOLVED  — closed out; an approved reply was sent. resolvedAt /
//               resolvedBy stamp who/when.
//   ARCHIVED  — operator filed it away without a reply (spam / duplicate /
//               non-actionable). Distinct from RESOLVED so analytics can
//               separate "answered" from "dismissed".
// Real ticketing (Intercom/Zendesk-grade) is a later phase; this is the
// first home for a customer's question so it doesn't vanish into an inbox.
enum SupportRequestStatus {
  NEW
  IN_REVIEW
  OPEN
  RESOLVED
  ARCHIVED
}

// Which front-door surface a Plaino conversation belongs to
// (feat/plaino-chatbot-marketing-support, 2026-06-06). Both modes share
// the /api/chat backbone + the PlainoConversation log; the mode selects
// the system prompt, the context loader, and the resolution paths.
//   MARKETING — anonymous site widget. No workspace. Sales-tuned prompt;
//               can capture a lead at the end of a qualified conversation.
//   SUPPORT   — authenticated in-app chat. Workspace context loaded;
//               answers from the knowledge substrate and can draft a
//               support reply into the operator review queue.
enum PlainoConversationMode {
  MARKETING
  SUPPORT
}

// Operator triage state for a captured marketing lead. Mirrors the
// InquiryStatus lifecycle shape (NEW → worked → terminal) but stays
// separate because a lead is a lighter-weight artifact than a /custom
// Inquiry — it carries the conversation that produced it, not a scoped
// engagement brief.
enum LeadCaptureStatus {
  NEW
  CONTACTED
  CONVERTED
  DECLINED
}

// Lifecycle of a human-creator brief — the structured handoff for
// brand-defining creative the fleet must NOT improvise in raw SVG/PNG
// (feedback_creative_assets_use_tools_or_humans). A brief is authored by the
// Creative discipline's router (creative-router), sent to an outside creator,
// and the finished asset is pasted back on the operator surface.
//   DRAFT     — packet assembled, not yet sent to a creator.
//   BRIEFED   — handed to a creator; awaiting delivery.
//   DELIVERED — creator returned an asset; awaiting acceptance review.
//   ACCEPTED  — asset met the acceptance criteria; in use.
//   REJECTED  — asset failed acceptance; re-brief or escalate.
//   CANCELLED — brief withdrawn before delivery.
enum CreatorBriefStatus {
  DRAFT
  BRIEFED
  DELIVERED
  ACCEPTED
  REJECTED
  CANCELLED
}

// The creative job a brief covers. Mirrors the brand-defining rows in
// docs/strategy/creative-asset-capability-2026-06-06/JOB_TO_TOOL_MATRIX.md
// that route to "human creator required" rather than a design-tool skill.
enum CreatorBriefKind {
  BRAND_MARK
  HERO_ILLUSTRATION
  MASCOT_ILLUSTRATION
  PHOTOGRAPHY_DIRECTION
  MOTION_IDENT
  PRINT_COLLATERAL
  OTHER
}

// WorkspaceMemoryEntry kind. Mirrors the four-bucket memory taxonomy
// already in use by the agent system:
//   USER       — facts about the people in the workspace (names, role
//                preferences, communication style).
//   FEEDBACK   — guidance Plaino has been given on how to work (avoid X,
//                always do Y, prefer this format).
//   PROJECT    — in-flight initiatives, deadlines, named entities the
//                customer is moving on.
//   REFERENCE  — pointers to where information lives (a Notion page, a
//                Drive folder, a CRM segment).
//
// Stored as a Prisma enum so the dispatcher's prompt-side bucketing
// stays loud at the type level and the customer-facing memory page can
// group entries cleanly. Adding a kind requires a migration.
enum WorkspaceMemoryKind {
  USER
  FEEDBACK
  PROJECT
  REFERENCE
}

model User {
  id                        String                       @id @default(uuid()) @db.Uuid
  email                     String                       @unique @db.Citext
  name                      String?
  isOperator                Boolean                      @default(false)
  /// Apple "Sign in with Apple" stable subject claim (the `sub` in the Apple
  /// identity token). Set the first time a user signs in with Apple; used to
  /// re-match a returning Apple user even when Apple withholds the email on
  /// subsequent logins. NULL for users who have only ever used magic link /
  /// passkey. One identity, multiple auth methods — see /api/auth/apple.
  appleSub                  String?                      @unique
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  memberships               Membership[]
  pushDevices               PushDevice[]
  decidedItems              WorkApprovalQueueItem[]      @relation("DecidedBy")
  configuredThresholds      WorkThresholdConfig[]        @relation("ConfiguredBy")
  configuredSkills          SkillConfig[]                @relation("SkillConfigBy")
  installedSkills           WorkspaceSkillInstallation[] @relation("SkillInstalledBy")
  pauseConfigs              WorkspacePauseConfig[]       @relation("PauseConfigBy")
  scheduleWindows           SkillScheduleWindow[]        @relation("ScheduleWindowBy")
  auditEntriesActor         AuditLog[]                   @relation("AuditActor")
  auditEntriesActAs         AuditLog[]                   @relation("AuditActingAs")
  magicLinkTokens           MagicLinkToken[]
  triagedInquiries          Inquiry[]                    @relation("InquiryTriagedBy")
  passkeys                  WebAuthnCredential[]
  supportRequests           SupportRequest[]             @relation("SupportRequestFrom")
  /// Wave-6: memberships this user has issued (audit lineage). SetNull so
  /// the inviter going away does not orphan the invited row.
  invitedMemberships        Membership[]                 @relation("MembershipInvitedBy")
  createdTeams              Team[]                       @relation("TeamCreatedBy")
  teamMemberships           TeamMembership[]
  disciplineHeadAssignments DisciplineHead[]             @relation("DisciplineHeadUser")
  disciplineHeadAssignedBy  DisciplineHead[]             @relation("DisciplineHeadAssignedBy")
  requiredApprovalItems     WorkApprovalQueueItem[]      @relation("WorkApprovalRequiredApprover")
  preferenceFeedback        PreferenceFeedback[]         @relation("PreferenceFeedbackBy")

  @@index([email])
}

model Workspace {
  id                       String                       @id @default(uuid()) @db.Uuid
  name                     String
  slug                     String                       @unique
  // Phase 1 audience tier (legacy). See WorkspaceTier comment.
  tier                     WorkspaceTier                @default(HIGH_TOUCH)
  // Canonical per-seat tier (product_spec.md §13.1). Drives pricing, gating,
  // and the marketing/[vertical] CTAs. Required on every workspace; defaults
  // REGULAR so existing Phase 1 realty workspaces backfill cleanly.
  verticalTier             WorkspaceVerticalTier        @default(REGULAR)
  // Vertical the workspace operates in. Required, defaults REAL_ESTATE for
  // Phase 1 backfill. Spec §13.2 lines 444–453.
  vertical                 Vertical                     @default(REAL_ESTATE)
  stateCode                String                       @default("GA") @db.VarChar(2)
  billingMode              WorkspaceBillingMode         @default(MANUAL_INVOICE)
  stripeCustomerId         String?                      @unique
  stripeSubscriptionId     String?                      @unique
  tierPriceUsdMonthly      Int? // hundredths of a dollar; populated for manual invoicing
  settings                 Json                         @default("{}")
  // Customer-initiated closure state. Flipped by
  // `lib/customer-data/closure.ts#initiateWorkspaceClosure` (BROKER_OWNER-
  // gated, typed-confirmation guarded). The hourly
  // `workspace-teardown-sweep` Inngest function reads
  // (closureStatus, scheduledHardPurgeAt) to decide which CLOSING workspaces
  // have aged out of the grace window and should hard-purge.
  closureStatus            WorkspaceClosureStatus       @default(ACTIVE)
  closingInitiatedAt       DateTime?
  /// The User who initiated closure. SetNull so the workspace row survives
  /// the user being removed (audit + billing remain queryable).
  closingInitiatedByUserId String?                      @db.Uuid
  /// UTC instant the hard purge becomes eligible. Set by
  /// `initiateWorkspaceClosure`; reset to NULL on cancel.
  scheduledHardPurgeAt     DateTime?
  /// UTC instant the hard purge actually ran (closureStatus = CLOSED).
  closedAt                 DateTime?
  /// Optional free-text reason the customer supplied at closure time.
  /// Captured for the operator/CS triage signal — never resurfaced to
  /// other customers.
  closureReason            String?
  /// Wave-4 — abandoned-signup sweep state. NULL = the customer has
  /// NOT completed Stripe Checkout (no card on file, no usable
  /// Subscription row). Set when the first `customer.subscription.created`
  /// webhook fires for the workspace's stripeCustomerId. The
  /// `stripe-abandoned-signup-sweep` Inngest cron reads this column
  /// to find workspaces that signed up but never finished checkout.
  signupSetupCompletedAt   DateTime?
  /// Wave-4 — when set, the workspace is "soft-deactivated" because
  /// the customer abandoned Stripe Checkout for >= 7 days. Skills + crons
  /// skip the workspace (`lib/billing/workspace-paused-gate.ts` honors
  /// this); the workspace UI shows a "Complete setup to resume Plaino"
  /// banner. Cleared when the customer completes checkout (the
  /// abandoned-signup sweep's resume path lifts the gate).
  setupDeactivatedAt       DateTime?
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  memberships              Membership[]
  workApprovalItems        WorkApprovalQueueItem[]
  thresholds               WorkThresholdConfig[]
  handoffs                 HandoffLogEntry[]
  flags                    ComplianceFlag[]
  capabilityProposals      CapabilityProposal[]
  invoices                 WorkspaceInvoice[]
  auditEntries             AuditLog[]
  onboardingState          OnboardingState?
  subscription             Subscription?
  integrationCredentials   IntegrationCredential[]
  webhookSubscriptions     WebhookSubscription[]
  webhookEvents            WebhookEvent[]
  knowledgeDocuments       KnowledgeDocument[]
  embeddings               Embedding[]
  supportRequests          SupportRequest[]
  preference               WorkspacePreference?
  preferenceSignals        PreferenceSignal[]
  preferenceFeedback       PreferenceFeedback[]
  chatThreads              ChatThread[]
  chatMessages             ChatMessage[]
  plainoConversations      PlainoConversation[]
  creatorBriefs            CreatorBrief[]
  memoryEntries            WorkspaceMemoryEntry[]
  llmUsageRecords          LlmUsageRecord[]
  briefings                WorkspaceBriefing[]
  skillConfigs             SkillConfig[]
  skillInstallations       WorkspaceSkillInstallation[]
  pauseConfigs             WorkspacePauseConfig[]
  skillScheduleWindows     SkillScheduleWindow[]
  lifecycleEvents          WorkspaceLifecycleEvent[]
  /// Wave-6 — sub-workspace groupings used by RBAC + roster. Teams are
  /// RLS-isolated per workspace.
  teams                    Team[]
  /// Wave-6 — per-discipline approver routing. Empty = "any qualified
  /// member can approve discipline items" (single-owner workspace default).
  disciplineHeads          DisciplineHead[]
  /// Wave-6 — every cron / Inngest entry seam writes a SkillRun row so
  /// scorecards report skipped + failed fires honestly, not just drafts.
  skillRuns                SkillRun[]
  /// Wave-4 (compliance rewrite-and-stage) — counsel red-lines feeding the
  /// learned-language rewrite loop. See CounselRedline.
  counselRedlines          CounselRedline[]

  @@index([slug])
  @@index([vertical])
  @@index([closureStatus, scheduledHardPurgeAt])
  @@index([signupSetupCompletedAt, setupDeactivatedAt])
}

// Phase 2 per-seat subscription. One row per workspace at most.
// Created at signup with a 30-day trial; status flips via webhook.
// Workspace.stripeCustomerId / .stripeSubscriptionId are the FK columns
// (kept as Strings on Workspace for Phase 1 back-compat); this model is
// the typed accessor for everything else. project_stripe_both_surfaces.
model Subscription {
  id                     String                @id @default(uuid()) @db.Uuid
  workspaceId            String                @unique @db.Uuid
  stripeSubscriptionId   String                @unique
  stripeCustomerId       String
  tier                   WorkspaceVerticalTier
  seatBand               SeatBand
  seats                  Int                   @default(1)
  status                 SubscriptionStatus
  trialEndsAt            DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean               @default(false)
  defaultPaymentMethodId String?
  /// Last value seen so cron warnings don't double-fire. Set by the
  /// trial-expiration cron when it emits a 7/3/1-day notice.
  lastTrialWarningDays   Int?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  workspace              Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  events                 BillingEvent[]

  @@index([status])
  @@index([trialEndsAt])
  @@index([stripeCustomerId])
}

// Append-only billing-event audit. One row per inbound Stripe event id;
// the @@unique on stripeEventId enforces idempotency at the database
// layer so retries are a true no-op. AuditLog continues to receive a
// summary row for cross-cutting audit (engineering_plan §5.2), but
// BillingEvent is the typed history view scoped to one subscription.
model BillingEvent {
  id             String        @id @default(uuid()) @db.Uuid
  subscriptionId String?       @db.Uuid
  workspaceId    String?       @db.Uuid
  type           String
  stripeEventId  String        @unique
  payload        Json
  receivedAt     DateTime      @default(now())
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([subscriptionId, receivedAt])
  @@index([workspaceId, receivedAt])
}

// Per-workspace onboarding wizard state. 1:1 with Workspace. Seeded on signup.
// completedSteps is an array of step ids (e.g. ["confirm_details",
// "connect_integration"]); currentStep is the next step id to render.
// product_spec.md §3.2 BO-5 (initial setup), §8.1 (onboarding-to-first-value).
//
// Wave-9 self-serve onboarding wizard adds:
//   - `pickedSkillSlugs`         — JSON array of skill catalog slugs the
//                                  customer ticked in the new "pick what to
//                                  track" step. Source of truth for what
//                                  the first-fire trigger executes.
//   - `firstFireRequestedAt`     — when the `agentplain/onboarding.first-
//                                  fire.requested` Inngest event was
//                                  dispatched. The polling watch panel on
//                                  the wizard's last step reads SkillRun
//                                  rows whose `firedAt >= firstFireRequestedAt`.
//   - `firstFireCompletedAt`     — stamped when at least one SkillRun for
//                                  this workspace lands after the request.
//                                  Used by the watch panel to switch from
//                                  "fetching" to "first fire landed."
model OnboardingState {
  id                   String    @id @default(uuid()) @db.Uuid
  workspaceId          String    @unique @db.Uuid
  currentStep          String    @default("confirm_details")
  completedSteps       Json      @default("[]")
  pickedSkillSlugs     Json      @default("[]")
  firstFireRequestedAt DateTime?
  firstFireCompletedAt DateTime?
  completedAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// Wave-4 — append-only lifecycle event log for the workspace billing /
// signup-completion journey. Closes the honesty gap PR #123 named: a
// workspace that signs up + gets a magic link but abandons Stripe
// Checkout exists with no usable Subscription. The
// `stripe-abandoned-signup-sweep` cron writes events here as it nudges,
// soft-deactivates, and archives those workspaces.
//
// Kinds:
//   SETUP_NUDGE_SENT  — first nudge ("finish setting up Plaino") email
//                       drafted; recorded with the message id in payload.
//   SETUP_DEACTIVATED — 7 days post-signup with no checkout; the gate
//                       flips on (skills + crons skip; the UI banner
//                       reads "Complete setup to resume Plaino").
//   SETUP_ARCHIVED    — 30 days post-signup with no resolution; the
//                       existing workspace-teardown sweep takes over via
//                       closureStatus=CLOSING + scheduledHardPurgeAt.
//   SETUP_RESUMED     — the customer completed checkout after a nudge /
//                       deactivation; the gate lifts and the workspace
//                       is restored.
//
// `noteEncrypted` is the v1 AES-256-GCM envelope so any contextual
// metadata (e.g. a Stripe Checkout Session id, a Stripe Customer id)
// is encrypted at rest. `payload` is non-sensitive JSON for indexing.
enum WorkspaceLifecycleEventKind {
  SETUP_NUDGE_SENT
  SETUP_DEACTIVATED
  SETUP_ARCHIVED
  SETUP_RESUMED
}

model WorkspaceLifecycleEvent {
  id            String                      @id @default(uuid()) @db.Uuid
  workspaceId   String                      @db.Uuid
  kind          WorkspaceLifecycleEventKind
  occurredAt    DateTime                    @default(now())
  /// AES-256-GCM v1 ciphertext for any free-form contextual note
  /// (Stripe Session id, error reason, operator comment). NULL when
  /// no note was captured.
  noteEncrypted String?
  /// Non-sensitive JSON metadata — kept queryable for the operator
  /// triage console (e.g. `{ "daysSinceSignup": 7 }`). Never carries
  /// emails, tokens, or anything that would belong in noteEncrypted.
  payload       Json                        @default("{}")
  workspace     Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, occurredAt])
  @@index([kind, occurredAt])
}

model Membership {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @db.Uuid
  workspaceId     String           @db.Uuid
  role            Role
  status          MembershipStatus @default(ACTIVE)
  /// Wave-6: who invited this user (NULL for the original founder row
  /// of every Phase-1 workspace). SetNull so the membership row survives
  /// inviter removal — audit context is preserved either way.
  invitedByUserId String?          @db.Uuid
  /// Wave-6: when the membership was revoked. status=DEACTIVATED was the
  /// only signal pre-wave-6; this column adds a queryable timestamp so the
  /// audit + roster views can show "removed N days ago".
  removedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy       User?            @relation("MembershipInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  teamMemberships TeamMembership[]

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
  @@index([workspaceId, status])
}

// Customer-defined work-execution gating. One config row per workspace+kind.
model WorkThresholdConfig {
  id                             String              @id @default(uuid()) @db.Uuid
  workspaceId                    String              @db.Uuid
  kind                           WorkApprovalKind
  requiresApprovalAboveSeverity  ComplianceSeverity?
  requiresApprovalForActionKinds String[]            @default([])
  autoApproveWhen                Json?
  configuredByUserId             String?             @db.Uuid
  configuredAt                   DateTime            @default(now())
  workspace                      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  configuredBy                   User?               @relation("ConfiguredBy", fields: [configuredByUserId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, kind])
}

// Work-execution decisions only (NEVER capability proposals). Polymorphic via (refTable, refId).
// Per project_skill_authority_vs_work_authority, customer-controlled, customer-visible.
model WorkApprovalQueueItem {
  id                     String             @id @default(uuid()) @db.Uuid
  workspaceId            String             @db.Uuid
  agentSlug              String
  kind                   WorkApprovalKind
  refTable               String
  refId                  String
  payload                Json
  status                 WorkApprovalStatus @default(PENDING)
  proposedAt             DateTime           @default(now())
  decidedAt              DateTime?
  decidedByUserId        String?            @db.Uuid
  decisionReason         String?
  /// Discipline this item belongs to — one of the 8 from `lib/disciplines`.
  /// NULL on legacy rows written before the discipline axis landed; the
  /// UI buckets NULL items into "All recent" (the fallback section).
  /// New inserts populate this where the producing skill / agent has a
  /// known discipline tag.
  discipline             String?
  /// Wave-6 — when a DisciplineHead is assigned for this item's
  /// discipline, the routing layer stamps that user's id here so only
  /// they can approve. NULL means "any qualified member can approve"
  /// (single-owner workspace default + workspaces with no head assigned).
  /// The runtime escalation cron that falls back to the owner after N
  /// days is queued for wave 7; today an unattended head means the item
  /// sits until reassigned.
  requiredApproverUserId String?            @db.Uuid
  workspace              Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  decidedBy              User?              @relation("DecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  requiredApprover       User?              @relation("WorkApprovalRequiredApprover", fields: [requiredApproverUserId], references: [id], onDelete: SetNull)
  skillRuns              SkillRun[]         @relation("SkillRunQueueItem")

  @@index([workspaceId, status])
  @@index([workspaceId, kind, status])
  @@index([workspaceId, discipline, status])
  @@index([requiredApproverUserId, status])
}

// Append-only inter-agent handoff log; powers per-listing/per-lead activity feeds.
model HandoffLogEntry {
  id                  String    @id @default(uuid()) @db.Uuid
  workspaceId         String    @db.Uuid
  fromAgent           String
  toAgent             String
  handoffType         String
  payload             Json
  relatedSubjectTable String?
  relatedSubjectId    String?
  occurredAt          DateTime  @default(now())
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, occurredAt])
  @@index([workspaceId, relatedSubjectTable, relatedSubjectId])
}

// Workspace-scoped compliance flag (rich data; status mirrors WorkApprovalQueueItem when gated).
model ComplianceFlag {
  id                String              @id @default(uuid()) @db.Uuid
  workspaceId       String              @db.Uuid
  sourceRecordTable String
  sourceRecordId    String
  raisedByAgent     String
  severity          ComplianceSeverity
  claim             String
  rule              String
  suggestedRewrite  String?
  state             ComplianceFlagState @default(OPEN)
  slaDueAt          DateTime?
  raisedAt          DateTime            @default(now())
  resolvedAt        DateTime?
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, state])
  @@index([workspaceId, slaDueAt])
}

// Operator-internal mirror of skill-development queue. Notion canonical; this is read-cache.
// Customer roles never query this table; operator-only RLS policy.
model CapabilityProposal {
  id              String                  @id @default(uuid()) @db.Uuid
  workspaceId     String?                 @db.Uuid // NULL = platform-level
  notionPageId    String?                 @unique
  targetAgentSlug String?
  proposer        String?
  body            String
  voiceBlock      String?
  voiceBlockHash  String?
  state           CapabilityProposalState @default(DRAFT)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  workspace       Workspace?              @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, state])
  @@index([state])
}

// Phase 1 manual invoicing: operator records a Stripe-issued invoice URL against a workspace.
// Phase 2 self-serve: rows created by webhook from invoice.created/.paid/.failed.
model WorkspaceInvoice {
  id               String    @id @default(uuid()) @db.Uuid
  workspaceId      String    @db.Uuid
  stripeInvoiceId  String?   @unique
  amountUsdCents   Int
  status           String    @default("draft")
  hostedInvoiceUrl String?
  pdfUrl           String?
  periodStart      DateTime?
  periodEnd        DateTime?
  issuedAt         DateTime  @default(now())
  paidAt           DateTime?
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, issuedAt])
}

// Append-only audit. acting_as_user_id non-null only during operator impersonation (Phase 2+).
model AuditLog {
  id             String     @id @default(uuid()) @db.Uuid
  actorUserId    String?    @db.Uuid
  actingAsUserId String?    @db.Uuid
  workspaceId    String?    @db.Uuid
  action         String
  targetTable    String?
  targetId       String?
  payload        Json?
  occurredAt     DateTime   @default(now())
  actor          User?      @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actingAs       User?      @relation("AuditActingAs", fields: [actingAsUserId], references: [id], onDelete: SetNull)
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, occurredAt])
  @@index([actorUserId, occurredAt])
}

// External-system OAuth credential. One row per (workspace, provider, account).
// Tokens are encrypted at rest via lib/security/encryption.ts (AES-256-GCM,
// v1 format). The raw access_token / refresh_token NEVER appear in this
// table or in logs — only the v1:iv:tag:ciphertext blobs.
//
// Status taxonomy (IntegrationCredentialStatus):
//   ACTIVE   — tokens valid; refresh path healthy.
//   EXPIRED  — access token past expires_at; refresh has not yet succeeded.
//   REVOKED  — customer revoked grant on the provider side. Detected when
//              refresh returns invalid_grant (Google) or AADSTS70000 (M365).
//   ERROR    — provider returned a non-recoverable error; operator triage.
//
// Per project_living_portable_architecture + feedback_no_silent_vendor_lock:
// provider-specific calls live in lib/integrations/<provider>/. This table
// is provider-neutral on its face; the provider column says which adapter
// owns the row.
model IntegrationCredential {
  id                    String                      @id @default(uuid()) @db.Uuid
  workspaceId           String                      @db.Uuid
  provider              IntegrationProvider
  /// Provider-specific account identifier (Google: sub claim from id_token /
  /// "me" identifier; M365: oid claim). Stable across logins; immutable.
  accountId             String
  /// Provider-reported email at consent time. Used for the operator UI label
  /// only — authorization decisions read accountId.
  accountEmail          String
  /// AES-256-GCM ciphertext of the OAuth access_token.
  accessTokenEncrypted  String
  /// AES-256-GCM ciphertext of the OAuth refresh_token. NULL only for short-
  /// lived flows that never returned one (shouldn't happen for Google with
  /// access_type=offline + prompt=consent).
  refreshTokenEncrypted String?
  /// Granted OAuth scopes, as the provider returned them. Stored verbatim so
  /// scope drift is observable.
  scopes                String[]                    @default([])
  /// UTC instant the current access token expires. Renewal threshold:
  /// refresh when expires_at is within 5 minutes.
  expiresAt             DateTime
  /// UTC instant of the most recent successful refresh. NULL until first
  /// refresh succeeds.
  lastRefreshedAt       DateTime?
  /// Non-secret, per-account routing data a provider needs on every call but
  /// that isn't a token: DocuSign REST base_uri + API account id, QuickBooks
  /// realmId + environment, Slack team id/name. NULL for providers that need
  /// none (Gmail, Outlook, Google Drive). Never store secrets here — tokens
  /// live encrypted in accessTokenEncrypted/refreshTokenEncrypted.
  providerMetadata      Json?
  status                IntegrationCredentialStatus @default(ACTIVE)
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  workspace             Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  webhookSubscriptions  WebhookSubscription[]

  @@unique([workspaceId, provider, accountId])
  @@index([workspaceId, provider])
  @@index([status, expiresAt])
}

// Live webhook subscription on the provider side. For Google Gmail this is
// a users.watch result; for M365 it'd be a Graph subscription. Each
// subscription belongs to exactly one IntegrationCredential — that's the
// credential whose tokens authenticated the watch call.
//
// Renewal model (Gmail): users.watch returns historyId + expiration (7 days
// per https://developers.google.com/workspace/gmail/api/guides/push as of
// 2026-05-11). Renewal = re-call users.watch before expiration; reuses the
// same topic. The cron in lib/inngest/functions/integration-renewal-sweep.ts
// sweeps rows with expires_at < now() + 24h and re-watches.
model WebhookSubscription {
  id                      String                    @id @default(uuid()) @db.Uuid
  workspaceId             String                    @db.Uuid
  integrationCredentialId String                    @db.Uuid
  provider                IntegrationProvider
  /// Provider-side subscription identifier. For Gmail this is the historyId
  /// from users.watch (the cursor for subsequent users.history.list calls).
  /// For Graph this is the Subscription.id GUID.
  subscriptionId          String
  /// The resource being watched. For Gmail: the user's "me" mailbox (we
  /// store the account email here for readability). For Graph: the resource
  /// path (e.g. "/me/messages").
  resource                String
  /// UTC instant the subscription expires. Gmail caps at 7 days from
  /// users.watch call.
  expiresAt               DateTime
  /// The push notification URL Pub/Sub posts to. For Gmail this is the
  /// Pub/Sub subscription's push endpoint (our app/api/webhooks/google/route).
  /// For Graph this is the notificationUrl on Graph subscription create.
  notificationUrl         String
  /// UTC instant of the most recent successful renewal. NULL until first
  /// renewal succeeds (the row is created with this NULL on subscribe).
  lastRenewedAt           DateTime?
  status                  WebhookSubscriptionStatus @default(ACTIVE)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  workspace               Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  credential              IntegrationCredential     @relation(fields: [integrationCredentialId], references: [id], onDelete: Cascade)
  events                  WebhookEvent[]

  @@index([workspaceId, provider])
  @@index([status, expiresAt])
  @@index([integrationCredentialId])
}

// Append-only webhook event audit. Every inbound Pub/Sub push lands a row
// here BEFORE any processing kicks off — write + ACK happens inside the
// 30-second Pub/Sub ACK deadline; the Inngest event handler picks up the
// row asynchronously. Per feedback_verify_after_create: the renewal cron
// and the value-loop skills in PR-C read this table (single source of
// truth) rather than the in-memory request body.
//
// `processed` flips true when the consuming skill in PR-C finishes its
// pass over the message. PR-B leaves it false and writes nothing further;
// PR-C closes the loop.
model WebhookEvent {
  id             String              @id @default(uuid()) @db.Uuid
  subscriptionId String              @db.Uuid
  /// Denormalized from WebhookSubscription so the RLS policy
  /// (20260526000000_add_integration_rls) can run as a plain
  /// column-equality check against app.workspace_id — same shape as every
  /// other workspace-scoped table. The drain consumer always reads
  /// WebhookSubscription anyway; the denormalization avoids a SECURITY
  /// DEFINER view or a per-row subquery in the policy USING clause.
  workspaceId    String              @db.Uuid
  /// The decoded Pub/Sub message payload as JSON. For Gmail this is the
  /// {emailAddress, historyId} envelope from Pub/Sub. Raw payload retained
  /// for replay + audit; never trimmed.
  rawPayload     Json
  receivedAt     DateTime            @default(now())
  processed      Boolean             @default(false)
  processedAt    DateTime?
  /// Last error string from a processing attempt. NULL while processed is
  /// false-and-untried. Populated when the drain consumer fails.
  error          String?
  /// Provider-derived dedupe key (Pub/Sub messageId for Gmail, Graph
  /// notification subscriptionId+changeType+resource for M365). Unique
  /// per subscription so an at-least-once delivery layer cleanly upserts
  /// instead of inflating the table with duplicate rows. NULL is allowed
  /// for historical rows written before this column existed.
  dedupeKey      String?
  /// Number of processing attempts the drain consumer has made. Bumped
  /// inside the consumer on every fire (succeeded OR failed). Used by
  /// the backoff logic to compute `nextAttemptAt` and by ops to spot
  /// rows that have hit the deadletter threshold.
  attemptCount   Int                 @default(0)
  /// When NULL the row is eligible immediately. When set, the drain
  /// consumer skips rows whose nextAttemptAt is in the future — exponential
  /// backoff after a transient failure. Reset to NULL on success.
  nextAttemptAt  DateTime?
  /// Set to true when attemptCount crosses the deadletter threshold. The
  /// drain consumer skips deadlettered rows entirely; operator surface
  /// has to intervene before retry. Distinct from `processed` so we can
  /// distinguish "done well" from "tried too many times, giving up".
  deadlettered   Boolean             @default(false)
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, dedupeKey])
  @@index([subscriptionId, receivedAt])
  @@index([processed, receivedAt])
  @@index([processed, deadlettered, nextAttemptAt])
  @@index([workspaceId])
}

// Knowledge substrate document (project_knowledge_substrate.md). The
// human-readable side of every embedded chunk. One Embedding row per
// document keeps the storage simple; a future "chunk into N pieces" pass
// would change Embedding into a many-to-one against KnowledgeDocument
// (the relation already supports it — Embedding.documentId is nullable
// only because we also embed non-document records like handoff entries
// in later phases).
//
// workspaceId NULL for SKILL / VERTICAL / CROSS_CUSTOMER / COMPLIANCE.
// workspaceId required for CUSTOMER. The RLS policy enforces this — see
// the trigger in the migration.
model KnowledgeDocument {
  id           String      @id @default(uuid()) @db.Uuid
  contextKind  ContextKind
  workspaceId  String?     @db.Uuid
  /// Short human-readable label — surfaces in operator audit logs + MCP
  /// search results. Required.
  title        String
  /// The full text body — chunkers in later passes split this into
  /// multiple Embedding rows. V1 = one embedding per document.
  body         String
  /// Optional canonical source URL (e.g. HUD fair-housing rule page).
  sourceUrl    String?
  /// Optional vertical slug for VERTICAL / COMPLIANCE rows that scope to
  /// one of the ten locked verticals. Matches `lib/verticals/<slug>/`.
  verticalSlug String?
  metadata     Json        @default("{}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  workspace    Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  embeddings   Embedding[]

  @@index([contextKind, workspaceId])
  @@index([contextKind, verticalSlug])
}

// One embedding row per (sourceType, sourceId). The vector column is a
// pgvector `vector(1536)` — dimension chosen to match OpenAI's
// `text-embedding-3-small` (1536 dims, $0.02/1M tokens, replaced ada-002
// in 2024 — same dims, ~5x cheaper). Per
// `feedback_no_silent_vendor_lock.md`, lib/knowledge/openai-embedding.ts
// is the only file that talks to OpenAI; everything else reads the
// 1536-dim float array from this column.
//
// The vector column is `Unsupported("vector(1536)")` because Prisma does
// not yet have a native vector type; all reads + writes happen through
// $queryRawUnsafe / $executeRawUnsafe inside lib/knowledge/pgvector-store.ts.
// Per Prisma docs (https://www.prisma.io/docs/orm/prisma-schema/data-model/unsupported-database-features),
// this is the canonical pattern for working with pgvector through Prisma.
model Embedding {
  id          String                      @id @default(uuid()) @db.Uuid
  /// FK to KnowledgeDocument when this embedding came from a doc. Null
  /// when the embedding is for an ad-hoc record (e.g. a HandoffLogEntry
  /// once that's wired in a later pass).
  documentId  String?                     @db.Uuid
  /// Free-form source-table label so non-document records (handoff logs,
  /// briefing snippets, etc.) can be embedded under the same table.
  /// V1: always "knowledge_document".
  sourceType  String
  /// Stable id of the source record. For knowledge_document this is the
  /// KnowledgeDocument.id; for future record types this is whatever the
  /// upstream table calls its primary key.
  sourceId    String
  workspaceId String?                     @db.Uuid
  contextKind ContextKind
  metadata    Json                        @default("{}")
  /// 1536-dim float vector. Prisma cannot read this column through the
  /// generated client; lib/knowledge/pgvector-store.ts does all I/O.
  vector      Unsupported("vector(1536)")
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  document    KnowledgeDocument?          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  workspace   Workspace?                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId])
  @@index([contextKind, workspaceId])
  @@index([documentId])
}

// Inquiry from /custom contact form. Stays inside the no-outbound
// architecture (per `project_no_outbound_architecture.md`): the row is
// persisted, one email to Conner's inbox fires, and the visitor sees a
// synchronous ack. No drip, no auto-follow. Operator triages via
// /operator/inquiries; downstream actions (workspace provisioning, Max
// engagement signing, Custom SOW) happen out of band and write back here.
//
// Not workspace-scoped at submit time — most inquiries come from prospects
// who don't yet have a workspace. The convertedWorkspaceId column gets
// populated when triage flips status to CONVERTED.
//
// RLS: operator-only read/write (policy in the migration). The submit
// path uses `withSystemContext` to insert under the operator GUC.
model Inquiry {
  id                    String        @id @default(uuid()) @db.Uuid
  // Free-text intake fields. Stored verbatim — triage reads them as-is.
  name                  String
  business              String
  /// One of CUSTOM_INQUIRY_VERTICAL_OPTIONS slugs (lib/custom-inquiry/types).
  /// Wider than the Vertical enum (includes "other"), so kept as a string.
  vertical              String
  seats                 String
  needs                 String
  email                 String
  inquiryType           InquiryType   @default(CUSTOM_SKILL_BUILD)
  /// Optional intensity prose — required at the form layer when inquiryType
  /// is MAX_SERVICE_ENGAGEMENT, optional otherwise. Captures multi-state,
  /// white-label, compliance-gate context that drives the quote.
  serviceIntensityNotes String?
  status                InquiryStatus @default(NEW)
  /// Resend / test-provider message id from the notification email. Null
  /// when the mail send failed; the row is still persisted so the inquiry
  /// is never silently lost.
  emailMessageId        String?
  /// Operator-typed prose captured during triage (`triageInquiryAction`).
  triageNotes           String?
  triagedAt             DateTime?
  triagedByUserId       String?       @db.Uuid
  /// Populated when the inquiry converts into a real workspace (Max
  /// engagement signed, Custom SOW signed). Soft reference — Inquiry rows
  /// outlive the workspace if a customer churns.
  convertedWorkspaceId  String?       @db.Uuid
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  triagedBy             User?         @relation("InquiryTriagedBy", fields: [triagedByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([inquiryType, status])
  @@index([createdAt])
}

// Plaino conversation log — one row per conversation across BOTH front-door
// surfaces (feat/plaino-chatbot-marketing-support, 2026-06-06). Feeds the
// drift sweep + voice-fingerprinting passes that keep Plaino's voice
// consistent everywhere a customer or prospect reads it.
//
// `turns` is the full exchange ([{ role, body, at }]) stored as an
// AES-256-GCM envelope at rest (lib/security/payload-crypto) — same posture
// as ChatMessage.body + WorkApprovalQueueItem.payload, because a SUPPORT
// transcript can carry customer specifics. MARKETING transcripts are
// anonymous but use the same envelope so there is one wire format to audit.
//
// RLS: workspace-isolation for SUPPORT rows (the signed-in member reads/
// writes their own workspace) PLUS operator-all (the marketing widget writes
// anonymous rows under withSystemContext, and the operator console reads
// every row). MARKETING rows have a NULL workspaceId and are therefore only
// reachable by the operator policy — a customer can never read them.
model PlainoConversation {
  id           String                 @id @default(uuid()) @db.Uuid
  mode         PlainoConversationMode
  /// NULL for MARKETING (anonymous). Set to the workspace for SUPPORT.
  workspaceId  String?                @db.Uuid
  /// Anonymous browser session id (MARKETING) or the user id (SUPPORT).
  /// Lets the drift sweep group multi-turn exchanges without joining users.
  sessionId    String
  /// Marketing route the widget was opened on (e.g. "/pricing"). NULL for
  /// SUPPORT — the workspace is the locus there.
  sourcePage   String?
  /// Encrypted envelope ({ enc: "v1:..." }) wrapping the turn array.
  turns        Json
  /// True once a MARKETING conversation produced a captured lead.
  leadCaptured Boolean                @default(false)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  workspace    Workspace?             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([mode, createdAt])
  @@index([workspaceId, createdAt])
}

// A lead captured by the marketing Plaino widget when an anonymous
// conversation produces qualified intent (feat/plaino-chatbot-marketing-
// support, 2026-06-06). Operator-only, exactly like Inquiry — the widget's
// capture endpoint persists under withSystemContext, and /operator/leads is
// the triage queue. No drip, no auto-reply (project_no_outbound_architecture).
model LeadCapture {
  id             String            @id @default(uuid()) @db.Uuid
  email          String
  name           String?
  business       String?
  /// Vertical slug the prospect identified with, or NULL. Free-form string
  /// (wider than the Vertical enum) so an off-list answer is still captured.
  vertical       String?
  /// One-line summary of what the prospect wants (demo / trial / question).
  intent         String
  /// Marketing route the conversation happened on (e.g. "/real-estate").
  sourcePage     String?
  /// Soft link to the PlainoConversation that produced the lead. No FK so a
  /// pruned conversation never blocks the lead row.
  conversationId String?           @db.Uuid
  status         LeadCaptureStatus @default(NEW)
  /// True when the conversation that produced this lead asked about Claude /
  /// Claude for Small Business ("why not just use Claude"). Lets the operator
  /// track the comparison-prospect cohort. Set at capture time, either from an
  /// explicit widget flag or by scanning the linked conversation turns.
  /// See project_sbm_wrapper_positioning_2026_06_06.
  askedAboutClaude Boolean         @default(false)
  /// Operator-typed prose captured during triage.
  notes          String?
  triagedAt      DateTime?
  triagedByUserId String?          @db.Uuid
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
  @@index([askedAboutClaude, createdAt])
}

// A structured handoff to an outside human creator for brand-defining work
// (feat/creative-asset-capability-2026-06-06). The fleet does NOT improvise
// brand assets in raw SVG/PNG — when a job is brand-defining or no design
// tool can hit the bar, the creative router assembles a CreatorBrief packet
// (brand tokens + references + delivery spec + acceptance criteria) and an
// operator dispatches it to a creator. The finished asset is pasted back at
// /operator/creative-briefs. See feedback_creative_assets_use_tools_or_humans
// and docs/strategy/creative-asset-capability-2026-06-06/ARCHITECTURE.md.
//
// Operator-only RLS, exactly like LeadCapture — `workspaceId` is an optional
// link (a brief can be platform-level brand work with no workspace). The
// packet + delivery payloads are stored as JSON; nothing here is encrypted
// because a creator brief carries brand tokens + a public-facing spec, not
// customer PII (the acceptance review keeps PII out by construction).
model CreatorBrief {
  id              String             @id @default(uuid()) @db.Uuid
  /// Optional link to the workspace the asset is for. NULL = platform-level
  /// agentplain brand work (e.g. the robot-dog mark itself).
  workspaceId     String?            @db.Uuid
  kind            CreatorBriefKind
  status          CreatorBriefStatus @default(DRAFT)
  /// One-line human-readable title (e.g. "Plaino — 'reviewing' pose").
  title           String
  /// The assembled brief packet: brand tokens snapshot, reference asset
  /// URLs/paths, delivery spec (dimensions/formats), and acceptance
  /// criteria. Shape mirrors CreatorBriefPacket in lib/creative-handoff.
  packet          Json
  /// The job-to-tool routing decision that sent this to a human rather than a
  /// tool — kept for audit ("why didn't a tool do this?"). Free-form slug,
  /// e.g. "brand-defining" or "no-tool-meets-bar".
  routedReason    String
  /// Creator the brief was sent to (name/handle/marketplace), set when an
  /// operator marks it BRIEFED. No outbound fires from here — the operator
  /// reaches the creator out of band (project_no_outbound_architecture).
  creatorRef      String?
  /// Where the delivered asset landed (Vercel Blob URL / path) + creator
  /// notes, set when an operator marks it DELIVERED. Shape mirrors
  /// CreatorDelivery in lib/creative-handoff.
  delivery        Json?
  /// Operator prose from the acceptance review (why accepted/rejected).
  reviewNotes     String?
  createdByAgent  String?
  decidedByUserId String?            @db.Uuid
  decidedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  workspace       Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([workspaceId, createdAt])
  @@index([kind, status])
}

// Magic-link tokens issued for sign-in. Single-use; consumed on verify.
model MagicLinkToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique // sha256 of raw token; raw token never stored
  purpose    String    @default("sign_in") // sign_in | sign_up | invite_accept
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

// WebAuthn / passkey credential. An ADDITIONAL sign-in option alongside the
// magic link (feat/passkey-auth, 2026-05-20) — magic link stays the fallback.
//
// Scoped to User, NOT Membership: authentication is a user-level act that
// resolves the default workspace afterward (exactly like verifyMagicLink),
// so a passkey must work regardless of which workspace the user lands in and
// must survive a single membership being deactivated. This mirrors
// MagicLinkToken.userId. (The task brief said "workspaceMemberId FK"; the
// codebase's auth model is unambiguously user-level, so the credential binds
// to the person, not a workspace seat.)
//
// publicKey + credentialId are NOT secrets (the public key is public by
// design, the credential id is an opaque handle), so unlike OAuth tokens
// they are stored in the clear — no lib/security/encryption pass. Replay
// protection comes from `counter`: every assertion must report a counter
// strictly greater than the stored value (when the authenticator uses a
// signature counter at all). Stored as BigInt because the spec permits a
// full uint32 which overflows Postgres INT.
model WebAuthnCredential {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  /// Base64URL credential id as returned by the authenticator. Unique across
  /// the whole table — the authenticate flow looks a credential up by this
  /// value alone (discoverable credentials carry no email).
  credentialId String    @unique
  /// Base64URL-encoded COSE public key (from verifyRegistrationResponse).
  publicKey    String
  /// Signature counter; replay-protection watermark. BigInt per spec uint32.
  counter      BigInt    @default(0)
  /// Authenticator transports hint (e.g. ["internal","hybrid"]). Stored so
  /// re-auth can pass allowCredentials transports for a faster prompt.
  transports   String[]  @default([])
  /// Customer-facing label ("MacBook Touch ID", "YubiKey"). Best-effort; the
  /// user can rename later. Defaults to a generic label at registration.
  label        String?
  /// Device-type + backup hints from registration — surfaced in the settings
  /// list so the user can tell a synced passkey from a single-device one.
  deviceType   String?
  backedUp     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A registered Expo push token for the native mobile app (feat/mobile-app-
// v2-polish, 2026-06-06). Scoped to User, NOT Membership: a push token
// belongs to a physical device the person carries, and notifications fan
// out per-user (the approval-ready ping). The same person may carry several
// devices, so the table is one-row-per-device, keyed by the Expo token.
//
// The token itself is NOT a secret (it's an opaque routing handle Expo
// issues; it can only deliver to that device via Expo's authenticated push
// service) so, like WebAuthnCredential.publicKey, it is stored in the clear.
//
// RLS: user-isolation (`app.user_id`) OR operator-all — the server-side
// approval-trigger fan-out runs under withSystemContext and reads every
// owner's devices, exactly like the briefing fan-out pattern.
model PushDevice {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  /// Expo push token, e.g. "ExponentPushToken[xxxxxxxx]". Unique across the
  /// table — re-registering the same device upserts on this handle so a
  /// reinstall never leaves a duplicate row delivering twice.
  expoPushToken String   @unique
  /// "ios" | "android" — surfaced in settings + lets the trigger pick a
  /// platform-specific payload if it ever needs to.
  platform     String
  /// Best-effort device label ("iPhone 15"), supplied by the client.
  deviceName   String?
  /// Set false when Expo reports the token is no longer registered
  /// (DeviceNotRegistered) so the trigger stops fanning out to it without
  /// deleting the audit row.
  enabled      Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
}

// Source that produced a preference signal. ONBOARDING_FORM = the
// set_preferences step in the wizard. DRAFT_EDIT = broker-owner edited a
// reply draft in /approvals. DRAFT_REJECT = broker-owner rejected a
// reply draft with (or without) a reason. The append-only signal log lets
// the prompt-injection layer reconstruct the active preferences from
// first principles (no in-memory cache; cold-start safe per
// feedback_cold_start_safe_agents.md).
enum PreferenceSignalSource {
  ONBOARDING_FORM
  DRAFT_EDIT
  DRAFT_REJECT
}

// Per-workspace preference state — one row per workspace. The "tell us
// once and it adjusts" claim from marketing/[vertical]/page.tsx + the
// onboarding set_preferences step lands here. Read every fire of the
// skill chain (per feedback_cold_start_safe_agents.md); written from
// (1) the onboarding wizard, (2) the approvals queue when a human
// edits/rejects a draft. NEVER cross-workspace.
//
// Fields kept deliberately simple — three input axes plus a learned-
// notes string the capture pass appends to. A future structured-notes
// model is fine; today the string composes into the draft prompt
// verbatim under a WORKSPACE-LEARNED PREFERENCES header.
model WorkspacePreference {
  id                  String    @id @default(uuid()) @db.Uuid
  workspaceId         String    @unique @db.Uuid
  /// Drafting tone selector. One of the three onboarding options
  /// (plain / warm-professional / formal). NULL = no preference set
  /// yet; the draft skill falls back to the vertical default.
  draftingTone        String?
  /// Free-text categorization dos/don'ts captured at onboarding —
  /// short prose the broker-owner typed (or the default we offered).
  /// Inlined verbatim into the categorize prompt under a
  /// WORKSPACE-CATEGORIZATION-NOTES section.
  categorizationNotes String?
  /// Calendar window preference label (e.g. "9-5 weekdays",
  /// "8-7 + Sat AM", "custom"). The schedule skill receives this and
  /// constrains slot proposals accordingly.
  calendarWindow      String?
  /// Learned-from-corrections bullets — newest first, capped at the
  /// most recent 20 entries by the capture path. Each entry is a one-
  /// line observation derived from a DRAFT_EDIT or DRAFT_REJECT
  /// signal. Inlined verbatim into the draft prompt.
  learnedDraftNotes   String[]  @default([])
  /// Disciplines the customer has explicitly turned OFF on the
  /// Discipline panel. Defaults to empty — every discipline is enabled
  /// for a new workspace, and the panel toggle adds to this list when
  /// the operator opts out. The panel toggle is the customer-facing
  /// activation surface from Strand 1 §5.2 (the UX wedge); the runtime
  /// wiring (skip vs. fire) deepens in later waves — this column is the
  /// truth source those later layers read.
  disabledDisciplines String[]  @default([])
  /// Wave-2 briefings generator mute toggle. NULL = enabled (the
  /// default). Non-null = the customer turned them off; the generator
  /// cron skips and the briefings page renders a "muted — turn back
  /// on" empty state. Per-workspace switch, not per-discipline.
  briefingsMutedAt    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// Append-only preference signal log. One row per captured signal so the
// audit trail is preserved even after the aggregated WorkspacePreference
// row is overwritten. Per feedback_cold_start_safe_agents.md: the future
// reconstructor reads this table to rebuild preferences from scratch.
model PreferenceSignal {
  id          String                 @id @default(uuid()) @db.Uuid
  workspaceId String                 @db.Uuid
  source      PreferenceSignalSource
  /// Short label of the captured axis (e.g. "tone", "length", "do",
  /// "dont", "categorization", "calendar"). Free-form so future signal
  /// kinds add without a migration.
  kind        String
  /// The captured prose itself — for DRAFT_EDIT this is a one-line
  /// observation derived from the edit diff. For DRAFT_REJECT it's the
  /// decisionReason verbatim. For ONBOARDING_FORM it's the value the
  /// broker-owner selected.
  text        String
  /// Polymorphic pointer to the source artifact (e.g. refTable=
  /// "WorkApprovalQueueItem", refId=<item id>). NULL for onboarding.
  refTable    String?
  refId       String?
  /// Snapshot of the edit for DRAFT_EDIT signals — original vs final
  /// body so a future learner can re-derive the observation. NULL for
  /// other sources.
  payload     Json?
  capturedAt  DateTime               @default(now())
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, capturedAt])
  @@index([workspaceId, source])
}

// Customer-facing closed-loop feedback on a specific drafted item.
// Distinct from the append-only PreferenceSignal log: PreferenceFeedback
// is the EXPLICIT, categorized correction the customer leaves on a draft
// in /approvals ("doesn't sound like us" → pick a category + reason). The
// weekly customer-feedback-drift-sweep aggregates these by
// (targetSkillSlug, category); ≥3 same-category corrections in a week
// queues a CapabilityProposal, and the /briefings "what we learned"
// section surfaces the aggregate back to the customer so the loop closes
// visibly. The capture path ALSO appends a learnedDraftNote so the very
// next draft reflects the correction (feedback_cold_start_safe_agents).
//
// RLS: workspace-scoped (customer reads/writes own rows; operators read
// all) — same shape as PreferenceSignal.
model PreferenceFeedback {
  id              String                     @id @default(uuid()) @db.Uuid
  workspaceId     String                     @db.Uuid
  /// The member who left the feedback. SetNull on user delete so the
  /// drift sweep still counts the correction after the account is gone.
  userId          String?                    @db.Uuid
  /// Slug of the skill/agent that produced the draft (= ApprovalRow
  /// agentSlug). The drift sweep groups on this.
  targetSkillSlug String
  /// The draft body as the fleet produced it, at feedback time. Capped at
  /// the boundary. Nullable: a feedback row can exist without a snapshot.
  originalDraft   String?
  /// The customer's corrected version, when supplied. NULL for pure
  /// "doesn't sound like us" feedback (no rewrite offered).
  correctedDraft  String?
  /// Free-text reason the customer typed. Required by the capture modal.
  reason          String
  category        PreferenceFeedbackCategory
  createdAt       DateTime                   @default(now())
  workspace       Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user            User?                      @relation("PreferenceFeedbackBy", fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, targetSkillSlug, category])
  @@index([createdAt])
}

// Customer support request (scaffold — feat/support-routing, 2026-05-20).
// First home for a customer's question so it lands in a durable, triageable
// place instead of disappearing into a personal inbox. Mirrors the Inquiry
// no-outbound posture (project_no_outbound_architecture): persist the row,
// fire ONE notification email to the support address, render a synchronous
// ack. No drip, no auto-reply.
//
// Framed as "message your service partner," not a helpdesk ticket
// (project_service_partnership_positioning). Workspace-scoped: the customer
// submits under their own workspace RLS context; operators read all rows.
model SupportRequest {
  id             String               @id @default(uuid()) @db.Uuid
  workspaceId    String               @db.Uuid
  /// The member (User) who sent the message. SetNull on user delete so the
  /// request survives for the operator even if the account is removed.
  fromUserId     String?              @db.Uuid
  subject        String
  body           String
  status         SupportRequestStatus @default(NEW)
  /// Resend / test-provider message id from the notification email. Null when
  /// the send failed; the row is still persisted so nothing is lost.
  emailMessageId String?
  /// When an operator approved a drafted reply and it was sent (status →
  /// RESOLVED). NULL until resolved. Set in lib/support/resolve-reply.ts.
  resolvedAt     DateTime?
  /// Operator User.id who approved + sent the resolving reply. Plain uuid
  /// (no FK relation) — mirrors the audit-actor convention; the operator
  /// account always outlives the request so SetNull semantics aren't needed.
  resolvedBy     String?              @db.Uuid
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fromUser       User?                @relation("SupportRequestFrom", fields: [fromUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([status, createdAt])
}

// Operator-only flag store. Source of truth for ops-managed kill-switches
// (Inngest pause/resume in particular — P0-4). Migrated out of process.env
// because env-backed flags only take effect on the next cold start, which
// gave us a 5+ minute pause-propagation lag. The DB row is read by every
// Inngest gate invocation; the env-var path remains as a cold-start cache /
// fallback when the DB is unreachable. See
// prisma/migrations/20260526120000_add_ops_flag/migration.sql for the RLS +
// FORCE shape. Every access goes through lib/ops/prisma-flag-store.ts under
// withSystemContext; bare prisma.opsFlag.* reads see zero rows.
model OpsFlag {
  /// Operator-visible flag name. For Inngest pause flags this matches the
  /// env-var name (e.g. INNGEST_FN_DISABLE_AGENTPLAIN_TRIAL_WARNINGS) so the
  /// DB path and env fallback are interchangeable with zero translation.
  name      String   @id
  /// Literal flag value. For pause flags, "true" = paused; anything else
  /// (incl. "false", missing row) = active. Strict equality, matching
  /// lib/inngest/disable-flag.ts.
  value     String
  updatedAt DateTime @updatedAt
  /// Free-text actor string. Not a User FK — the writer can be a system
  /// identity ("system"), a CLI invocation ("cli:throttle.ts"), or a
  /// specific operator ("user:<uuid>").
  updatedBy String?
  /// Optional operator note about why the flag was flipped. Pure
  /// documentation; the gate does not read it.
  note      String?

  @@index([updatedAt])
}

/// Talk-to-Plaino chat thread. One per workspace in v1 (deferred:
/// multi-thread / archive UI — see PR description). Holds the
/// customer ↔ Plaino conversation that drives the `/talk` surface.
/// Workspace-isolated under RLS (see migration policy
/// `chat_thread_workspace_isolation`).
model ChatThread {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @db.Uuid
  /// Display title for the thread. Defaults to "talk with Plaino" in
  /// v1; v2 may auto-summarize from the first exchange.
  title       String        @default("talk with Plaino")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]

  @@index([workspaceId, updatedAt])
}

/// One message in a Plaino chat thread. `body` is encrypted at rest
/// with the v1 envelope (`lib/security/encryption` — `v1:iv:tag:ct`)
/// because the customer routinely pastes account details, addresses,
/// and other PII into chat. `metadata` carries the dispatcher's
/// classification (ANSWER / REGISTER / DECLINE_HONESTLY) and any
/// registered SupportRequest id when the message hand-off happened.
model ChatMessage {
  id                   String                 @id @default(uuid()) @db.Uuid
  threadId             String                 @db.Uuid
  workspaceId          String                 @db.Uuid
  /// "customer" — the human; "plaino" — the named service partner.
  /// Stored as a String (not an enum) because v2 may introduce a
  /// "system" role for status pings; widening a String column is
  /// schema-cheap, widening an enum is not.
  role                 String
  /// AES-256-GCM ciphertext using the v1 envelope. NEVER plaintext at
  /// rest. The dispatcher + render path are the only readers; they
  /// always decrypt before surfacing.
  body                 String
  /// Dispatcher decision + any registered SupportRequest id.
  /// NULLABLE — v2 may attach more metadata; v1 is best-effort.
  metadata             Json?
  createdAt            DateTime               @default(now())
  thread               ChatThread             @relation(fields: [threadId], references: [id], onDelete: Cascade)
  workspace            Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /// Memory entries Plaino extracted from this message. Cascade-deletes
  /// when the source message is cleared so a deleted turn doesn't leave
  /// a dangling sourceChatMessageId reference.
  derivedMemoryEntries WorkspaceMemoryEntry[] @relation("MemoryFromChatMessage")

  @@index([threadId, createdAt])
  @@index([workspaceId, createdAt])
}

/// Customer-persistent memory for Plaino. Read at dispatch time so the
/// service partner has continuity across sessions; written by the
/// extract-from-conversation pass after each turn. Workspace-isolated
/// under RLS (same posture as ChatThread / ChatMessage).
///
/// `body` is encrypted at rest with the v1 envelope
/// (`lib/security/encryption` — `v1:iv:tag:ct`) because customers will
/// inevitably surface PII (a teammate's name, an account number, a
/// vendor email) into a memory entry. `title` is plaintext so the
/// memory page + the dispatcher's bucketing logic can list and filter
/// without round-tripping every row through decryption; the extractor
/// is instructed to keep PII out of the title.
///
/// `pinned = true` means the customer asked Plaino to always include
/// this entry. The dispatcher cap-budgets unpinned entries but never
/// drops pinned ones — pin is the customer's load-bearing knob.
model WorkspaceMemoryEntry {
  id                  String              @id @default(uuid()) @db.Uuid
  workspaceId         String              @db.Uuid
  kind                WorkspaceMemoryKind
  /// Short label used in UI lists + dispatcher prompts. NOT encrypted.
  /// The extractor is instructed to keep PII out of this field.
  title               String
  /// AES-256-GCM ciphertext using the v1 envelope. NEVER plaintext at
  /// rest. The dispatcher + memory UI are the only readers; they always
  /// decrypt before surfacing.
  body                String
  /// Optional FK back to the ChatMessage Plaino learned this from. Lets
  /// the memory page link "→ from this turn" so the customer can verify
  /// where Plaino picked it up. SetNull on message delete: the memory
  /// outlives a thread cleanup.
  sourceChatMessageId String?             @db.Uuid
  /// True when the customer pinned this entry — the dispatcher always
  /// includes pinned entries, never drops them for budget pressure.
  pinned              Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  /// Bumped every time the dispatcher includes the entry in a prompt.
  /// Lets future eviction passes prefer "stale and unpinned" entries
  /// without reading the chat log.
  lastReadAt          DateTime?
  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceChatMessage   ChatMessage?        @relation("MemoryFromChatMessage", fields: [sourceChatMessageId], references: [id], onDelete: SetNull)

  /// Composite index for the dispatcher's per-fire read — "pinned first,
  /// then by recency, scoped to this workspace + kind." Postgres uses it
  /// to satisfy the ORDER BY pinned DESC, createdAt DESC pattern without
  /// a sort step.
  @@index([workspaceId, kind, pinned, createdAt])
  @@index([workspaceId, pinned, updatedAt])
}

/// Wave-4 — counsel-feedback redline loop for compliance rewrite-and-stage
/// (`lib/agents/sentinel/redline-store.ts`). When counsel red-lines a
/// sentinel rewrite suggestion (or hand-corrects a flagged phrase), the
/// operator records ONE row here capturing the rule that fired, the
/// normalized clause pattern, and the language counsel ACTUALLY wants used.
/// Once a (workspace, vertical, rule, clausePattern) bucket accumulates
/// LEARNED_LANGUAGE_THRESHOLD (5) agreeing red-lines, the rewrite engine
/// embeds that learned language VERBATIM in future suggestions — no LLM
/// call, no re-derivation. This is the durable state that makes the loop
/// cold-start-safe: the engine re-reads it on every fire.
///
/// `id` is created WITHOUT a DB default (Prisma generates @default(uuid())
/// client-side) so this table adds ZERO entries to prisma/schema-drift-
/// baseline.sql — matching the PlainoConversation / LeadCapture convention.
///
/// RLS: operator-only (mirrors LeadCapture). The compliance sweep + the
/// operator counsel-review console run under withSystemContext; a customer
/// never reads another workspace's counsel corrections.
model CounselRedline {
  id                String    @id @default(uuid()) @db.Uuid
  workspaceId       String    @db.Uuid
  /// Vertical slug the red-line buckets under (`real-estate`, `mortgage`…).
  verticalSlug      String    @db.VarChar(64)
  /// Corpus rule id that fired the flag this red-line corrects
  /// (e.g. `fha-hud-literal-triggers`).
  ruleId            String    @db.VarChar(128)
  /// Normalized clause pattern (lowercased, whitespace-collapsed matched
  /// phrase). The rewrite engine looks up learned language by this key, so
  /// the recorder MUST normalize identically (normalizeClausePattern).
  clausePattern     String
  /// The language counsel wants used in place of the offending phrase. Plain
  /// text; generic clause language, NOT a specific customer draft (no PII).
  preferredLanguage String
  /// Optional counsel rationale, surfaced to the operator on review.
  rationale         String?
  /// Who recorded it — counsel name / bar # or operator id. Audit only.
  recordedBy        String?
  createdAt         DateTime  @default(now())
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// The learned-language reducer reads "all red-lines for this rule in this
  /// workspace+vertical, newest first" on every rewrite fire — this index
  /// satisfies that filter + ORDER BY without a scan.
  @@index([workspaceId, verticalSlug, ruleId, createdAt])
}

/// Wave-2 skill marketplace. One row per workspace × skill that the
/// customer has touched. NO ROW = "default-installed when the catalog
/// says runtime=live; not installed otherwise" (see
/// `lib/skills/marketplace.ts`). A row with `disabledAt IS NULL`
/// means the customer explicitly installed the skill (or, for
/// default-installed skills, never touched it). `disabledAt` non-null
/// means the customer uninstalled at that timestamp.
///
/// The runtime callers (sweep candidate listers + the webhook chain)
/// read this table at fire time and skip skills that resolve to
/// "not installed". Per `feedback_cold_start_safe_agents` this is a
/// per-fire durable read, never cached.
model WorkspaceSkillInstallation {
  id                String    @id @default(uuid()) @db.Uuid
  workspaceId       String    @db.Uuid
  /// Matches `lib/skills/<slug>/` and `SKILL_CATALOG.slug`.
  skillSlug         String    @db.VarChar(64)
  installedAt       DateTime  @default(now())
  installedByUserId String?   @db.Uuid
  /// NULL = currently installed. Non-null = uninstalled at that ts.
  disabledAt        DateTime?
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  installedBy       User?     @relation("SkillInstalledBy", fields: [installedByUserId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, skillSlug])
  @@index([workspaceId, disabledAt])
}

/// Wave-2 per-skill config. One row per workspace × skill. The
/// customer adjusts knobs from the settings UI (wait days for
/// follow-up-chaser, priority keywords for inbox-triage, default
/// meeting length for the scheduler), and the skill's runtime caller
/// reads + applies the config on every fire.
///
/// `configJson` is encrypted at rest with the v1 envelope
/// (`lib/security/encryption` — `v1:iv:tag:ct`) because customers
/// will inevitably put PII in a config (sender allowlists, paralegal
/// email cc lists). Shapes live in `lib/skills/config.ts` as typed
/// interfaces; persisted as JSON inside the envelope.
model SkillConfig {
  id                 String    @id @default(uuid()) @db.Uuid
  workspaceId        String    @db.Uuid
  /// Matches `lib/skills/<slug>/`. Free-form so adding a skill is
  /// not a migration.
  skillSlug          String    @db.VarChar(64)
  /// AES-256-GCM v1-envelope ciphertext. NEVER plaintext at rest.
  configJson         String
  configuredByUserId String?   @db.Uuid
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  configuredBy       User?     @relation("SkillConfigBy", fields: [configuredByUserId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, skillSlug])
}

/// Wave-5 customer-controlled fleet pause (vacation / PTO / firm
/// closure / cutover window). The skill-fire gate consults active
/// rows on every fire and short-circuits when NOW is inside the
/// window — same shape the subscription-state gate uses, but
/// customer-set rather than billing-driven.
///
/// `pausedDisciplineIds` is an empty array when the pause applies to
/// every discipline (the common case for vacation). A non-empty
/// array narrows the pause to the named disciplines so a firm can
/// say "I'm out of office — pause customer-facing comms but keep
/// finance fires going."
///
/// `reasonEncrypted` is AES-256-GCM v1-envelope ciphertext (per
/// lib/security/encryption) because customers will inevitably put
/// PII in the reason ("out for surgery", "Q4 board prep", etc.).
/// NULL when the customer skipped the optional reason field.
model WorkspacePauseConfig {
  id                  String    @id @default(uuid()) @db.Uuid
  workspaceId         String    @db.Uuid
  /// UTC instant the pause window opens.
  pausedFrom          DateTime
  /// UTC instant the pause window closes (the gate auto-resumes the
  /// fleet at this timestamp on the next fire).
  pausedUntil         DateTime
  /// Empty array = all disciplines paused. Non-empty = narrows to
  /// the listed discipline ids (one of the 8 in lib/disciplines).
  pausedDisciplineIds String[]  @default([])
  /// AES-256-GCM v1-envelope ciphertext. NULL when reason was not
  /// provided.
  reasonEncrypted     String?
  createdByUserId     String?   @db.Uuid
  createdAt           DateTime  @default(now())
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy           User?     @relation("PauseConfigBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, pausedUntil])
  @@index([pausedFrom, pausedUntil])
}

/// Wave-5 per-skill scheduling window. One row per (workspace, skill)
/// pair. When present, the skill-fire gate only allows fires whose
/// NOW (rendered into the workspace's TZ) falls inside the window.
/// Absent = no window = fires anytime (the historical default).
///
/// `daysOfWeek` is 0..6 where 0 = Sunday (Date.getDay() native).
/// `startHourLocal` / `endHourLocal` are 0..23. If `endHourLocal` <=
/// `startHourLocal` the window is treated as inclusive of midnight
/// (e.g. 22..6 = nights). `workspaceTimezone` is an IANA TZ ID; the
/// gate uses Intl.DateTimeFormat to compute the local hour/day on
/// each fire — no DST-stale caching.
model SkillScheduleWindow {
  id                 String    @id @default(uuid()) @db.Uuid
  workspaceId        String    @db.Uuid
  /// Matches `lib/skills/<slug>/` and `SKILL_CATALOG.slug`.
  skillSlug          String    @db.VarChar(64)
  /// 0..6 (0 = Sunday) — Date.getDay() native.
  daysOfWeek         Int[]     @default([])
  /// 0..23 local hour the window opens.
  startHourLocal     Int
  /// 0..23 local hour the window closes (exclusive).
  endHourLocal       Int
  /// IANA timezone id, e.g. "America/New_York".
  workspaceTimezone  String    @db.VarChar(64)
  configuredByUserId String?   @db.Uuid
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  configuredBy       User?     @relation("ScheduleWindowBy", fields: [configuredByUserId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, skillSlug])
  @@index([workspaceId])
}

/// Wave-2 briefings generator. The page at
/// /app/workspace/[id]/briefings has promised "Briefings land here at
/// 9am ET each workday" since the read-only Notion provider shipped
/// (audit §8 #5, 2026-05-28) — but no generator existed and the page
/// always rendered empty. The wave-2 generator cron writes into this
/// table; the page reads from it and decrypts the body.
///
/// `body` is encrypted at rest with the v1 envelope
/// (`lib/security/encryption` — `v1:iv:tag:ct`) because briefings
/// quote real customer threads. `summary` is a non-PII aggregate
/// (counts + categories) the page can render for previews without
/// decrypting.
model WorkspaceBriefing {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  /// ISO Y-M-D (UTC) the briefing covers. One row per workspace per
  /// day; the @@unique guarantees idempotent cron retries.
  forDate     String    @db.VarChar(10)
  /// AES-256-GCM v1-envelope ciphertext. NEVER plaintext at rest.
  body        String
  /// Aggregate counts + top categories. Shape defined in
  /// `lib/skills/briefing-generator/types.ts#BriefingSummary`.
  summary     Json      @default("{}")
  /// READY / FAILED / EMPTY (no activity in window). Future statuses
  /// may include MUTED for the customer-facing mute path.
  status      String    @default("READY") @db.VarChar(16)
  generatedAt DateTime  @default(now())
  emailedAt   DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, forDate])
  @@index([workspaceId, generatedAt])
}

// Per-LLM-call token + cost accounting. One row per successful
// LLM completion that carries a workspaceId in its meta (the
// LoggingLlmProvider drops workspaceId-less calls instead of fabricating
// a fake tag — see lib/billing/usage/recorder.ts). Cost is captured at
// write time using current list pricing in micro-cents so the row
// remains source-of-truth even if pricing later shifts. `stripeReportedAt`
// is the marker for the daily Stripe meter-emission cron; NULL = backlog,
// non-NULL = already reported (idempotent).
//
// RLS isolation matches every other workspace-scoped table (operator
// sees all; otherwise workspaceId GUC must match). See
// prisma/migrations/20260528400000_add_llm_usage_record/migration.sql.
model LlmUsageRecord {
  id                  String           @id @default(uuid()) @db.Uuid
  workspaceId         String           @db.Uuid
  model               String
  inputTokens         Int              @default(0)
  outputTokens        Int              @default(0)
  cacheCreationTokens Int              @default(0)
  cacheReadTokens     Int              @default(0)
  /// Computed at write time from `pricing.ts` using Anthropic list rates.
  /// BigInt micro-cents to avoid rounding drift across millions of rows.
  costMicroCents      BigInt           @default(0)
  sourceSurface       LlmSourceSurface
  /// Daily Stripe-meter cron sets this once a row has been reported as a
  /// usage record on the workspace's Subscription. NULL = backlog.
  stripeReportedAt    DateTime?
  createdAt           DateTime         @default(now())
  workspace           Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// Window aggregations + per-surface breakdown on the billing page.
  @@index([workspaceId, createdAt(sort: Desc)])
  /// Daily Stripe cron sweep — only unreported rows. Postgres partial
  /// index keeps the cron's scan tiny once backlog drains.
  @@index([workspaceId, stripeReportedAt], map: "LlmUsageRecord_workspace_meter_idx")
}

// Wave-6 — sub-workspace grouping. A workspace can have many teams; each
// member may belong to multiple teams (TeamMembership is the join table).
// RLS isolates per workspace. Teams DO NOT today gate skill access — that
// remains workspace-wide. The team axis is the foundation for future
// per-team discipline scoping; today it powers roster grouping + the
// future "this team can approve discipline X" rule (wave 7).
model Team {
  id              String           @id @default(uuid()) @db.Uuid
  workspaceId     String           @db.Uuid
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  createdByUserId String?          @db.Uuid
  /// Soft delete. Read paths filter `archivedAt IS NULL` unless explicitly
  /// asked for the archive.
  archivedAt      DateTime?
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy       User?            @relation("TeamCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  memberships     TeamMembership[]

  @@unique([workspaceId, name])
  @@index([workspaceId, archivedAt])
}

model TeamMembership {
  id           String     @id @default(uuid()) @db.Uuid
  teamId       String     @db.Uuid
  userId       String     @db.Uuid
  /// Membership on the workspace — kept as a hard FK so removing a
  /// workspace-membership cascades the team-membership rows. (User-only
  /// FK would leave dangling team rows after a workspace removal.)
  membershipId String     @db.Uuid
  joinedAt     DateTime   @default(now())
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([membershipId])
}

// Wave-6 — per-discipline approver routing. When a workspace assigns a
// head for `legal`, every new WorkApprovalQueueItem with discipline=legal
// gets `requiredApproverUserId` stamped to that user's id; only they can
// approve. The runtime escalation cron (fall back to owner after N idle
// days) is queued for wave 7; today an unattended head means the item
// sits until reassigned.
model DisciplineHead {
  id               String    @id @default(uuid()) @db.Uuid
  workspaceId      String    @db.Uuid
  discipline       String
  userId           String    @db.Uuid
  assignedAt       DateTime  @default(now())
  assignedByUserId String?   @db.Uuid
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user             User      @relation("DisciplineHeadUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy       User?     @relation("DisciplineHeadAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, discipline])
  @@index([userId])
}

// Wave-6 — SkillRun audit. Every cron / Inngest entry seam writes a row
// before any expensive work; the outcome column is updated at end. The
// per-discipline scorecards (wave-5) used to read approval-queue rows
// only, which made skipped + failed fires invisible. Wave-6 migrates the
// scorecards to read from SkillRun so the customer-facing numbers report
// honestly.
enum SkillRunOutcome {
  /// A draft was produced + persisted to the approval queue.
  DRAFTED
  /// The skill completed without producing a draft. This is the
  /// "no-op success" case — the input did not warrant a draft.
  SUCCEEDED_NO_DRAFT
  /// The workspace is paused (Stripe / setup / explicit pause). The fire
  /// was gated upstream and never entered the per-skill body.
  SKIPPED_PAUSED
  /// The skill is not installed in this workspace.
  SKIPPED_UNINSTALLED
  /// The skill is installed but outside its configured schedule window
  /// (wave-5 SkillScheduleWindow).
  SKIPPED_WINDOW
  /// The discipline this skill belongs to is disabled in the workspace's
  /// discipline activation map.
  SKIPPED_DISCIPLINE_DISABLED
  /// Dry-run flag was set — the skill body executed but is short-circuited
  /// without writing artifacts.
  SKIPPED_DRY_RUN
  /// The skill body threw or returned a structured error. `errorMessage`
  /// is the cap-truncated error.
  FAILED
}

model SkillRun {
  id           String                 @id @default(uuid()) @db.Uuid
  workspaceId  String                 @db.Uuid
  /// Slug from the marketplace registry. NOT a foreign key — skill rows
  /// don't live in the DB. The runtime is the source of truth.
  skillSlug    String
  /// Discipline tag from the registry (one of the 8) — duplicated here so
  /// the per-discipline scorecard query is a single-table scan.
  discipline   String?
  firedAt      DateTime               @default(now())
  completedAt  DateTime?
  outcome      SkillRunOutcome
  durationMs   Int?
  /// Short error message (cap-truncated at write time) for failed runs.
  /// Never the full stack — that's logged elsewhere; this column is for
  /// the customer-facing "why isn't my fleet running" tile.
  errorMessage String?
  /// When `outcome=DRAFTED`, links to the approval queue row this run
  /// produced. SetNull so the run row survives queue-item deletion.
  queueItemId  String?                @db.Uuid
  workspace    Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  queueItem    WorkApprovalQueueItem? @relation("SkillRunQueueItem", fields: [queueItemId], references: [id], onDelete: SetNull)

  @@index([workspaceId, firedAt(sort: Desc)])
  @@index([workspaceId, skillSlug, firedAt(sort: Desc)])
  @@index([workspaceId, discipline, firedAt(sort: Desc)])
  @@index([workspaceId, outcome, firedAt(sort: Desc)])
  /// Cross-workspace feed ordering for /operator/fleet (Stream D.1). The
  /// operator inspector reads the newest N runs across ALL workspaces ordered
  /// by firedAt; the per-workspace indexes above are workspace-leading and
  /// can't serve that scan. firedAt-leading index, with workspaceId trailing
  /// so workspace-filtered feed queries still use it. Matches the
  /// (timestamp DESC, workspaceId) shape the build plan calls for.
  @@index([firedAt(sort: Desc), workspaceId])
}
