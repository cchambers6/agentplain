// agentplain Phase 1 — broker-owner-only customer surface.
// Schema is deliberately small. Phase 2 adds operator overlay + multi-workspace.
// Phase 3 native adds AGENT role, AgentSeat, DraftReply, Thread.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

enum Role {
  BROKER_OWNER
  AGENT
}

enum MembershipStatus {
  INVITED
  ACTIVE
  DEACTIVATED
}

// Legacy Phase 1 tier — pre-§13 audience-tier framing (Spec lines 117–149).
// Kept on Workspace for backward-compat with shipped Phase 1 invoices / billing
// modes. New product surfaces read Workspace.verticalTier instead. Slated for
// drop in Phase 2 alongside the migration plan in §13.7 of product_spec.md.
enum WorkspaceTier {
  HIGH_TOUCH
  SCALED
}

// agentplain — nine launch verticals. Mirrors project_vertical_tier_mapping
// and product_spec.md §13.2. Medical practices intentionally excluded per
// feedback_no_new_verticals_finish_locked (reactivate when a HIPAA customer
// asks). Adding a vertical requires a memory-tracked decision.
enum Vertical {
  REAL_ESTATE
  MORTGAGE
  INSURANCE
  PROPERTY_MANAGEMENT
  TITLE_ESCROW
  RECRUITING
  HOME_SERVICES
  CPA
  LAW
  RIA
}

// Per-seat tier ladder ratified 2026-05-09. Supersedes WorkspaceTier above.
// Pricing in lib/pricing/tiers.ts; mapping verticals→tiers in lib/verticals.
// product_spec.md §13.1 lines 420–441.
enum WorkspaceVerticalTier {
  REGULAR
  PLUS
  MAX
}

enum WorkspaceBillingMode {
  MANUAL_INVOICE
  STRIPE_SUBSCRIPTION
}

// Per-seat subscription lifecycle. Mirrors Stripe's subscription.status
// taxonomy 1:1 so webhook payloads upsert without translation. PAUSED is
// intentionally omitted — Phase 2 doesn't expose pause-collection on
// agentplain's surface (project_stripe_both_surfaces lines 78–80).
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  INCOMPLETE
  INCOMPLETE_EXPIRED
  CANCELED
  UNPAID
}

// Seat-band axis for the per-seat ladder. Five self-serve bands; the 100+
// "enterprise" row in the canonical table is handled out-of-band via a
// custom build engagement (project_stripe_both_surfaces lines 17–26 + 57–59).
// The enum value is also the Stripe lookup_key suffix so the pricing table,
// the Stripe Prices, and the Subscription row share one stable identifier.
enum SeatBand {
  SEATS_1
  SEATS_2_9
  SEATS_10_24
  SEATS_25_49
  SEATS_50_99
}

enum WorkApprovalKind {
  COMPLIANCE_FLAG
  LISTING_RECOMMENDATION
  BUYER_INQUIRY_REPLY_DRAFT
  PRICING_RECOMMENDATION
}

enum WorkApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
  EXPIRED
}

enum ComplianceSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  BLOCKER
}

enum ComplianceFlagState {
  OPEN
  TRIAGED_KEEP
  TRIAGED_REWRITE
  TRIAGED_BLOCK
  RESOLVED
}

enum CapabilityProposalState {
  DRAFT
  AWAITING_VOICE_BLOCK
  AWAITING_REVIEW
  RATIFIED
  REJECTED
  SUPERSEDED
}

// Integration provider taxonomy. GOOGLE = Gmail + Calendar (Phase 1 ships
// Gmail only). M365 (Outlook + Graph) follows in a separate PR once the
// Google path is validated on Conner's dogfood inbox. New providers added
// only after the existing one passes the functional acceptance bar per
// feedback_integration_acceptance_is_functional.
enum IntegrationProvider {
  GOOGLE
  M365
}

// Credential lifecycle states. ACTIVE = tokens valid and refresh-eligible.
// EXPIRED = access token past expiry AND refresh attempt has not yet
// succeeded; refresh cron tries each fire. REVOKED = customer revoked the
// grant on the provider side (detected when refresh returns invalid_grant).
// ERROR = a non-recoverable provider response (e.g. provider returned 4xx
// other than 401, or a malformed token payload).
enum IntegrationCredentialStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
}

// Webhook subscription lifecycle. ACTIVE = subscription created and not
// near expiry. EXPIRING = within 24h of expires_at; renewal cron picks it
// up. EXPIRED = past expires_at, renewal failed. RENEWAL_FAILED = last
// renewal attempt returned a provider error; cron will retry. UNSUBSCRIBED
// = explicit unsubscribe by operator action.
enum WebhookSubscriptionStatus {
  ACTIVE
  EXPIRING
  EXPIRED
  RENEWAL_FAILED
  UNSUBSCRIBED
}

// Inquiry intake type. Drives operator triage on /operator/inquiries and
// the SLA framing in the customer-facing confirmation. CUSTOM_SKILL_BUILD
// is the existing /custom path (custom skill, integration, white-label,
// bespoke compliance, dedicated success). MAX_SERVICE_ENGAGEMENT is the
// quote-based Max-tier path per `project_stripe_both_surfaces.md` (Max is
// ad-hoc, not productized in Stripe). NOT_SURE keeps visitors who can't
// self-classify out of the failure mode of picking wrong.
enum InquiryType {
  CUSTOM_SKILL_BUILD
  MAX_SERVICE_ENGAGEMENT
  NOT_SURE
}

// Operator triage state for an Inquiry. NEW is the post-submit default;
// TRIAGED_* records Conner's routing decision; DECLINED removes the row
// from the active queue; CONVERTED is the terminal happy-path (workspace
// created, Max engagement signed, or Custom SOW signed — the audit trail
// is in AuditLog, not in this enum).
enum InquiryStatus {
  NEW
  TRIAGED_CUSTOM
  TRIAGED_MAX
  TRIAGED_BOTH
  DECLINED
  CONVERTED
}

// Knowledge substrate context kinds (per project_knowledge_substrate.md).
// Five scopes the fleet's customer-facing answers draw from:
//   SKILL          — capability documentation (read/categorize/coordinate/schedule/draft)
//   CUSTOMER       — workspace-scoped knowledge (CRM facts, prefs, history)
//   VERTICAL       — pattern-level vertical knowledge (real estate vs CPA vs law)
//   CROSS_CUSTOMER — anonymized fleet learnings derived offline
//   COMPLIANCE     — state-by-state + per-vertical rule corpus (fair housing, RESPA, etc.)
//
// workspaceId is NULL for every kind EXCEPT CUSTOMER. The RLS policy on
// Embedding + KnowledgeDocument enforces that customer queries see their
// own rows + every non-customer-scoped row.
enum ContextKind {
  SKILL
  CUSTOMER
  VERTICAL
  CROSS_CUSTOMER
  COMPLIANCE
}

model User {
  id                   String                  @id @default(uuid()) @db.Uuid
  email                String                  @unique @db.Citext
  name                 String?
  isOperator           Boolean                 @default(false)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  memberships          Membership[]
  decidedItems         WorkApprovalQueueItem[] @relation("DecidedBy")
  configuredThresholds WorkThresholdConfig[]   @relation("ConfiguredBy")
  auditEntriesActor    AuditLog[]              @relation("AuditActor")
  auditEntriesActAs    AuditLog[]              @relation("AuditActingAs")
  magicLinkTokens      MagicLinkToken[]
  triagedInquiries     Inquiry[]               @relation("InquiryTriagedBy")

  @@index([email])
}

model Workspace {
  id                     String                  @id @default(uuid()) @db.Uuid
  name                   String
  slug                   String                  @unique
  // Phase 1 audience tier (legacy). See WorkspaceTier comment.
  tier                   WorkspaceTier           @default(HIGH_TOUCH)
  // Canonical per-seat tier (product_spec.md §13.1). Drives pricing, gating,
  // and the marketing/[vertical] CTAs. Required on every workspace; defaults
  // REGULAR so existing Phase 1 realty workspaces backfill cleanly.
  verticalTier           WorkspaceVerticalTier   @default(REGULAR)
  // Vertical the workspace operates in. Required, defaults REAL_ESTATE for
  // Phase 1 backfill. Spec §13.2 lines 444–453.
  vertical               Vertical                @default(REAL_ESTATE)
  stateCode              String                  @default("GA") @db.VarChar(2)
  billingMode            WorkspaceBillingMode    @default(MANUAL_INVOICE)
  stripeCustomerId       String?                 @unique
  stripeSubscriptionId   String?                 @unique
  tierPriceUsdMonthly    Int? // hundredths of a dollar; populated for manual invoicing
  settings               Json                    @default("{}")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  memberships            Membership[]
  workApprovalItems      WorkApprovalQueueItem[]
  thresholds             WorkThresholdConfig[]
  handoffs               HandoffLogEntry[]
  flags                  ComplianceFlag[]
  capabilityProposals    CapabilityProposal[]
  invoices               WorkspaceInvoice[]
  auditEntries           AuditLog[]
  onboardingState        OnboardingState?
  subscription           Subscription?
  integrationCredentials IntegrationCredential[]
  webhookSubscriptions   WebhookSubscription[]
  knowledgeDocuments     KnowledgeDocument[]
  embeddings             Embedding[]

  @@index([slug])
  @@index([vertical])
}

// Phase 2 per-seat subscription. One row per workspace at most.
// Created at signup with a 30-day trial; status flips via webhook.
// Workspace.stripeCustomerId / .stripeSubscriptionId are the FK columns
// (kept as Strings on Workspace for Phase 1 back-compat); this model is
// the typed accessor for everything else. project_stripe_both_surfaces.
model Subscription {
  id                     String                @id @default(uuid()) @db.Uuid
  workspaceId            String                @unique @db.Uuid
  stripeSubscriptionId   String                @unique
  stripeCustomerId       String
  tier                   WorkspaceVerticalTier
  seatBand               SeatBand
  seats                  Int                   @default(1)
  status                 SubscriptionStatus
  trialEndsAt            DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean               @default(false)
  defaultPaymentMethodId String?
  /// Last value seen so cron warnings don't double-fire. Set by the
  /// trial-expiration cron when it emits a 7/3/1-day notice.
  lastTrialWarningDays   Int?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  workspace              Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  events                 BillingEvent[]

  @@index([status])
  @@index([trialEndsAt])
  @@index([stripeCustomerId])
}

// Append-only billing-event audit. One row per inbound Stripe event id;
// the @@unique on stripeEventId enforces idempotency at the database
// layer so retries are a true no-op. AuditLog continues to receive a
// summary row for cross-cutting audit (engineering_plan §5.2), but
// BillingEvent is the typed history view scoped to one subscription.
model BillingEvent {
  id             String        @id @default(uuid()) @db.Uuid
  subscriptionId String?       @db.Uuid
  workspaceId    String?       @db.Uuid
  type           String
  stripeEventId  String        @unique
  payload        Json
  receivedAt     DateTime      @default(now())
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([subscriptionId, receivedAt])
  @@index([workspaceId, receivedAt])
}

// Per-workspace onboarding wizard state. 1:1 with Workspace. Seeded on signup.
// completedSteps is an array of step ids (e.g. ["confirm_details",
// "connect_integration"]); currentStep is the next step id to render.
// product_spec.md §3.2 BO-5 (initial setup), §8.1 (onboarding-to-first-value).
model OnboardingState {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @unique @db.Uuid
  currentStep    String    @default("confirm_details")
  completedSteps Json      @default("[]")
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Membership {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @db.Uuid
  workspaceId String           @db.Uuid
  role        Role
  status      MembershipStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
}

// Customer-defined work-execution gating. One config row per workspace+kind.
model WorkThresholdConfig {
  id                             String              @id @default(uuid()) @db.Uuid
  workspaceId                    String              @db.Uuid
  kind                           WorkApprovalKind
  requiresApprovalAboveSeverity  ComplianceSeverity?
  requiresApprovalForActionKinds String[]            @default([])
  autoApproveWhen                Json?
  configuredByUserId             String?             @db.Uuid
  configuredAt                   DateTime            @default(now())
  workspace                      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  configuredBy                   User?               @relation("ConfiguredBy", fields: [configuredByUserId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, kind])
}

// Work-execution decisions only (NEVER capability proposals). Polymorphic via (refTable, refId).
// Per project_skill_authority_vs_work_authority, customer-controlled, customer-visible.
model WorkApprovalQueueItem {
  id              String             @id @default(uuid()) @db.Uuid
  workspaceId     String             @db.Uuid
  agentSlug       String
  kind            WorkApprovalKind
  refTable        String
  refId           String
  payload         Json
  status          WorkApprovalStatus @default(PENDING)
  proposedAt      DateTime           @default(now())
  decidedAt       DateTime?
  decidedByUserId String?            @db.Uuid
  decisionReason  String?
  workspace       Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  decidedBy       User?              @relation("DecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([workspaceId, kind, status])
}

// Append-only inter-agent handoff log; powers per-listing/per-lead activity feeds.
model HandoffLogEntry {
  id                  String    @id @default(uuid()) @db.Uuid
  workspaceId         String    @db.Uuid
  fromAgent           String
  toAgent             String
  handoffType         String
  payload             Json
  relatedSubjectTable String?
  relatedSubjectId    String?
  occurredAt          DateTime  @default(now())
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, occurredAt])
  @@index([workspaceId, relatedSubjectTable, relatedSubjectId])
}

// Workspace-scoped compliance flag (rich data; status mirrors WorkApprovalQueueItem when gated).
model ComplianceFlag {
  id                String              @id @default(uuid()) @db.Uuid
  workspaceId       String              @db.Uuid
  sourceRecordTable String
  sourceRecordId    String
  raisedByAgent     String
  severity          ComplianceSeverity
  claim             String
  rule              String
  suggestedRewrite  String?
  state             ComplianceFlagState @default(OPEN)
  slaDueAt          DateTime?
  raisedAt          DateTime            @default(now())
  resolvedAt        DateTime?
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, state])
  @@index([workspaceId, slaDueAt])
}

// Operator-internal mirror of skill-development queue. Notion canonical; this is read-cache.
// Customer roles never query this table; operator-only RLS policy.
model CapabilityProposal {
  id              String                  @id @default(uuid()) @db.Uuid
  workspaceId     String?                 @db.Uuid // NULL = platform-level
  notionPageId    String?                 @unique
  targetAgentSlug String?
  proposer        String?
  body            String
  voiceBlock      String?
  voiceBlockHash  String?
  state           CapabilityProposalState @default(DRAFT)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  workspace       Workspace?              @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, state])
  @@index([state])
}

// Phase 1 manual invoicing: operator records a Stripe-issued invoice URL against a workspace.
// Phase 2 self-serve: rows created by webhook from invoice.created/.paid/.failed.
model WorkspaceInvoice {
  id               String    @id @default(uuid()) @db.Uuid
  workspaceId      String    @db.Uuid
  stripeInvoiceId  String?   @unique
  amountUsdCents   Int
  status           String    @default("draft")
  hostedInvoiceUrl String?
  pdfUrl           String?
  periodStart      DateTime?
  periodEnd        DateTime?
  issuedAt         DateTime  @default(now())
  paidAt           DateTime?
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, issuedAt])
}

// Append-only audit. acting_as_user_id non-null only during operator impersonation (Phase 2+).
model AuditLog {
  id             String     @id @default(uuid()) @db.Uuid
  actorUserId    String?    @db.Uuid
  actingAsUserId String?    @db.Uuid
  workspaceId    String?    @db.Uuid
  action         String
  targetTable    String?
  targetId       String?
  payload        Json?
  occurredAt     DateTime   @default(now())
  actor          User?      @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actingAs       User?      @relation("AuditActingAs", fields: [actingAsUserId], references: [id], onDelete: SetNull)
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, occurredAt])
  @@index([actorUserId, occurredAt])
}

// External-system OAuth credential. One row per (workspace, provider, account).
// Tokens are encrypted at rest via lib/security/encryption.ts (AES-256-GCM,
// v1 format). The raw access_token / refresh_token NEVER appear in this
// table or in logs — only the v1:iv:tag:ciphertext blobs.
//
// Status taxonomy (IntegrationCredentialStatus):
//   ACTIVE   — tokens valid; refresh path healthy.
//   EXPIRED  — access token past expires_at; refresh has not yet succeeded.
//   REVOKED  — customer revoked grant on the provider side. Detected when
//              refresh returns invalid_grant (Google) or AADSTS70000 (M365).
//   ERROR    — provider returned a non-recoverable error; operator triage.
//
// Per project_living_portable_architecture + feedback_no_silent_vendor_lock:
// provider-specific calls live in lib/integrations/<provider>/. This table
// is provider-neutral on its face; the provider column says which adapter
// owns the row.
model IntegrationCredential {
  id                    String                      @id @default(uuid()) @db.Uuid
  workspaceId           String                      @db.Uuid
  provider              IntegrationProvider
  /// Provider-specific account identifier (Google: sub claim from id_token /
  /// "me" identifier; M365: oid claim). Stable across logins; immutable.
  accountId             String
  /// Provider-reported email at consent time. Used for the operator UI label
  /// only — authorization decisions read accountId.
  accountEmail          String
  /// AES-256-GCM ciphertext of the OAuth access_token.
  accessTokenEncrypted  String
  /// AES-256-GCM ciphertext of the OAuth refresh_token. NULL only for short-
  /// lived flows that never returned one (shouldn't happen for Google with
  /// access_type=offline + prompt=consent).
  refreshTokenEncrypted String?
  /// Granted OAuth scopes, as the provider returned them. Stored verbatim so
  /// scope drift is observable.
  scopes                String[]                    @default([])
  /// UTC instant the current access token expires. Renewal threshold:
  /// refresh when expires_at is within 5 minutes.
  expiresAt             DateTime
  /// UTC instant of the most recent successful refresh. NULL until first
  /// refresh succeeds.
  lastRefreshedAt       DateTime?
  status                IntegrationCredentialStatus @default(ACTIVE)
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  workspace             Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  webhookSubscriptions  WebhookSubscription[]

  @@unique([workspaceId, provider, accountId])
  @@index([workspaceId, provider])
  @@index([status, expiresAt])
}

// Live webhook subscription on the provider side. For Google Gmail this is
// a users.watch result; for M365 it'd be a Graph subscription. Each
// subscription belongs to exactly one IntegrationCredential — that's the
// credential whose tokens authenticated the watch call.
//
// Renewal model (Gmail): users.watch returns historyId + expiration (7 days
// per https://developers.google.com/workspace/gmail/api/guides/push as of
// 2026-05-11). Renewal = re-call users.watch before expiration; reuses the
// same topic. The cron in lib/inngest/functions/integration-renewal-sweep.ts
// sweeps rows with expires_at < now() + 24h and re-watches.
model WebhookSubscription {
  id                      String                    @id @default(uuid()) @db.Uuid
  workspaceId             String                    @db.Uuid
  integrationCredentialId String                    @db.Uuid
  provider                IntegrationProvider
  /// Provider-side subscription identifier. For Gmail this is the historyId
  /// from users.watch (the cursor for subsequent users.history.list calls).
  /// For Graph this is the Subscription.id GUID.
  subscriptionId          String
  /// The resource being watched. For Gmail: the user's "me" mailbox (we
  /// store the account email here for readability). For Graph: the resource
  /// path (e.g. "/me/messages").
  resource                String
  /// UTC instant the subscription expires. Gmail caps at 7 days from
  /// users.watch call.
  expiresAt               DateTime
  /// The push notification URL Pub/Sub posts to. For Gmail this is the
  /// Pub/Sub subscription's push endpoint (our app/api/webhooks/google/route).
  /// For Graph this is the notificationUrl on Graph subscription create.
  notificationUrl         String
  /// UTC instant of the most recent successful renewal. NULL until first
  /// renewal succeeds (the row is created with this NULL on subscribe).
  lastRenewedAt           DateTime?
  status                  WebhookSubscriptionStatus @default(ACTIVE)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  workspace               Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  credential              IntegrationCredential     @relation(fields: [integrationCredentialId], references: [id], onDelete: Cascade)
  events                  WebhookEvent[]

  @@index([workspaceId, provider])
  @@index([status, expiresAt])
  @@index([integrationCredentialId])
}

// Append-only webhook event audit. Every inbound Pub/Sub push lands a row
// here BEFORE any processing kicks off — write + ACK happens inside the
// 30-second Pub/Sub ACK deadline; the Inngest event handler picks up the
// row asynchronously. Per feedback_verify_after_create: the renewal cron
// and the value-loop skills in PR-C read this table (single source of
// truth) rather than the in-memory request body.
//
// `processed` flips true when the consuming skill in PR-C finishes its
// pass over the message. PR-B leaves it false and writes nothing further;
// PR-C closes the loop.
model WebhookEvent {
  id             String              @id @default(uuid()) @db.Uuid
  subscriptionId String              @db.Uuid
  /// The decoded Pub/Sub message payload as JSON. For Gmail this is the
  /// {emailAddress, historyId} envelope from Pub/Sub. Raw payload retained
  /// for replay + audit; never trimmed.
  rawPayload     Json
  receivedAt     DateTime            @default(now())
  processed      Boolean             @default(false)
  processedAt    DateTime?
  /// Last error string from a processing attempt. NULL while processed is
  /// false-and-untried. Populated when a PR-C consumer fails.
  error          String?
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, receivedAt])
  @@index([processed, receivedAt])
}

// Knowledge substrate document (project_knowledge_substrate.md). The
// human-readable side of every embedded chunk. One Embedding row per
// document keeps the storage simple; a future "chunk into N pieces" pass
// would change Embedding into a many-to-one against KnowledgeDocument
// (the relation already supports it — Embedding.documentId is nullable
// only because we also embed non-document records like handoff entries
// in later phases).
//
// workspaceId NULL for SKILL / VERTICAL / CROSS_CUSTOMER / COMPLIANCE.
// workspaceId required for CUSTOMER. The RLS policy enforces this — see
// the trigger in the migration.
model KnowledgeDocument {
  id           String      @id @default(uuid()) @db.Uuid
  contextKind  ContextKind
  workspaceId  String?     @db.Uuid
  /// Short human-readable label — surfaces in operator audit logs + MCP
  /// search results. Required.
  title        String
  /// The full text body — chunkers in later passes split this into
  /// multiple Embedding rows. V1 = one embedding per document.
  body         String
  /// Optional canonical source URL (e.g. HUD fair-housing rule page).
  sourceUrl    String?
  /// Optional vertical slug for VERTICAL / COMPLIANCE rows that scope to
  /// one of the ten locked verticals. Matches `lib/verticals/<slug>/`.
  verticalSlug String?
  metadata     Json        @default("{}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  workspace    Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  embeddings   Embedding[]

  @@index([contextKind, workspaceId])
  @@index([contextKind, verticalSlug])
}

// One embedding row per (sourceType, sourceId). The vector column is a
// pgvector `vector(1536)` — dimension chosen to match OpenAI's
// `text-embedding-3-small` (1536 dims, $0.02/1M tokens, replaced ada-002
// in 2024 — same dims, ~5x cheaper). Per
// `feedback_no_silent_vendor_lock.md`, lib/knowledge/openai-embedding.ts
// is the only file that talks to OpenAI; everything else reads the
// 1536-dim float array from this column.
//
// The vector column is `Unsupported("vector(1536)")` because Prisma does
// not yet have a native vector type; all reads + writes happen through
// $queryRawUnsafe / $executeRawUnsafe inside lib/knowledge/pgvector-store.ts.
// Per Prisma docs (https://www.prisma.io/docs/orm/prisma-schema/data-model/unsupported-database-features),
// this is the canonical pattern for working with pgvector through Prisma.
model Embedding {
  id           String             @id @default(uuid()) @db.Uuid
  /// FK to KnowledgeDocument when this embedding came from a doc. Null
  /// when the embedding is for an ad-hoc record (e.g. a HandoffLogEntry
  /// once that's wired in a later pass).
  documentId   String?            @db.Uuid
  /// Free-form source-table label so non-document records (handoff logs,
  /// briefing snippets, etc.) can be embedded under the same table.
  /// V1: always "knowledge_document".
  sourceType   String
  /// Stable id of the source record. For knowledge_document this is the
  /// KnowledgeDocument.id; for future record types this is whatever the
  /// upstream table calls its primary key.
  sourceId     String
  workspaceId  String?            @db.Uuid
  contextKind  ContextKind
  metadata     Json               @default("{}")
  /// 1536-dim float vector. Prisma cannot read this column through the
  /// generated client; lib/knowledge/pgvector-store.ts does all I/O.
  vector       Unsupported("vector(1536)")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  document     KnowledgeDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  workspace    Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId])
  @@index([contextKind, workspaceId])
  @@index([documentId])
}

// Inquiry from /custom contact form. Stays inside the no-outbound
// architecture (per `project_no_outbound_architecture.md`): the row is
// persisted, one email to Conner's inbox fires, and the visitor sees a
// synchronous ack. No drip, no auto-follow. Operator triages via
// /operator/inquiries; downstream actions (workspace provisioning, Max
// engagement signing, Custom SOW) happen out of band and write back here.
//
// Not workspace-scoped at submit time — most inquiries come from prospects
// who don't yet have a workspace. The convertedWorkspaceId column gets
// populated when triage flips status to CONVERTED.
//
// RLS: operator-only read/write (policy in the migration). The submit
// path uses `withSystemContext` to insert under the operator GUC.
model Inquiry {
  id                    String         @id @default(uuid()) @db.Uuid
  // Free-text intake fields. Stored verbatim — triage reads them as-is.
  name                  String
  business              String
  /// One of CUSTOM_INQUIRY_VERTICAL_OPTIONS slugs (lib/custom-inquiry/types).
  /// Wider than the Vertical enum (includes "other"), so kept as a string.
  vertical              String
  seats                 String
  needs                 String
  email                 String
  inquiryType           InquiryType    @default(CUSTOM_SKILL_BUILD)
  /// Optional intensity prose — required at the form layer when inquiryType
  /// is MAX_SERVICE_ENGAGEMENT, optional otherwise. Captures multi-state,
  /// white-label, compliance-gate context that drives the quote.
  serviceIntensityNotes String?
  status                InquiryStatus  @default(NEW)
  /// Resend / test-provider message id from the notification email. Null
  /// when the mail send failed; the row is still persisted so the inquiry
  /// is never silently lost.
  emailMessageId        String?
  /// Operator-typed prose captured during triage (`triageInquiryAction`).
  triageNotes           String?
  triagedAt             DateTime?
  triagedByUserId       String?        @db.Uuid
  /// Populated when the inquiry converts into a real workspace (Max
  /// engagement signed, Custom SOW signed). Soft reference — Inquiry rows
  /// outlive the workspace if a customer churns.
  convertedWorkspaceId  String?        @db.Uuid
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  triagedBy             User?          @relation("InquiryTriagedBy", fields: [triagedByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([inquiryType, status])
  @@index([createdAt])
}

// Magic-link tokens issued for sign-in. Single-use; consumed on verify.
model MagicLinkToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  tokenHash  String    @unique // sha256 of raw token; raw token never stored
  purpose    String    @default("sign_in") // sign_in | sign_up | invite_accept
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
